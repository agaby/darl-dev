ruleset DisplayRules
{
	input categorical reqchart  {true,false};
	input categorical reqstats  {true,false};
	input categorical reqspark  {true,false};
	input categorical reqmap  {true,false};
	input categorical reqgrid  {true,false};
	input categorical reqtable  {true,false};
	input numeric numrecipes;
	input numeric datesum;
	input numeric attributes;
	input categorical locationitem  {true,false};
	input numeric rows;
	input categorical search  {true,false};

	output textual decision;

	if search is false then decision will be "handle";
	if rows is > 0 then decision will be "nodata";

	if reqstats is true then decision will be "stats";
	if reqmap is true and locationitem is true then decision will be "map";

	if rows is = 1 and numrecipes is = 1 then decision will be "single";
	if rows is = 1 then decision will be "stats";

	if reqmap is true then decision will be "map";
	if reqchart is true then decision will be "chart";
	if reqspark is true then decision will be "spark";
	if reqgrid is true then decision will be "grid";
	if reqtable is true then decision will be "table";

	if locationitem is true then decision will be "map";

	if attributes is > 5 then decision will be "grid";

	if numrecipes is > 1 and attributes is = 1 and datesum is = 1 then decision will be "stats";

	if numrecipes is > 1 and attributes is < 2 and datesum is > 1 then decision will be "spark";

	if datesum is > 1 then decision will be "chart-grid";

	otherwise if anything then decision will be "chart-grid";
}