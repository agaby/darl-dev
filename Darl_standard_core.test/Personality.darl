    //Rule definitions
    if anything then RawE will be sum( item1 , item6 , item11 , item16 , item20 , item28 , item36 , item40 , item45 , item51 , item55 , item58 , item61 , item63 , item67 , item69 , item72 , item78 , item90 , item94 , item24 , item33 , item47 ) confidence 1.00;
