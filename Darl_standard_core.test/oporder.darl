ruleset oporder
{
	input numeric EARNED_INCOME {{low, 0,0}, {high, 1000000, 1000000}};
	input numeric DIVIDEND_INCOME {{low, 0,0}, {high, 1000000, 1000000}};

	output numeric TOTAL_ALLOWANCES;

	constant Basic_Allowance 8;
	constant Allowance_Income_Limit 100;

	if anything then TOTAL_ALLOWANCES will be EARNED_INCOME * Basic_Allowance + DIVIDEND_INCOME * Allowance_Income_Limit;
}