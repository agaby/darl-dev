ruleset bluewave_pricing
{
  input categorical bizmodel {_product,service};
  input categorical marketPreference {research,direct};
  input categorical support {yes,no};
  input categorical supportWebEmailIM {yes,no};
  input categorical docCreation {true,false};
  input categorical docCategory {true,false};
  input categorical advanced {true,false};
  input categorical machineLearning {true,false};
  input categorical textMining {true,false};
  input categorical chatbot {true,false};
  input categorical chatbotFaceBookOther {true,false};
  input categorical salesTracking {no,tracked,tracked_analyzed};
  input categorical salesteamAccess {yes,no};
  input categorical customerAccess {yes,no};
  input categorical offerChangeable {yes,no};
  input categorical autoOptimize {yes,no};
  input numeric productCount {{low,1,6},{medium,7,12},{high,13,Infinity}};
  input categorical productOptions {no,some,all};
  input categorical estimatingComplex {no,sometimes,often,always};
  input categorical pdfEstimate {no,yes};
  input categorical estimate_transmission {download,email_client,email_you};
  input categorical billing_system {no,yes};
  input numeric serviceCount {{low,1,6},{medium,7,12},{high,13,Infinity}};
  input categorical serviceCharging {by_hour,by_project,by_use};
  input categorical serviceOptions {no,some,all};
  input categorical serviceEstimatingComplex {no,sometimes,often,always};
  input categorical servicePdfEstimate {no,yes};
  input categorical service_estimate_transmission {download,email_client,email_you};
  input categorical service_billing_system {no,yes};
  input categorical marketingPlatformsSocialMedia{yes,no};
  input categorical marketingPlatformsEmailWebsitesOther {yes,no};
  input categorical socialMediaPlatforms {twitter, facebook, linkedin, other };
  input categorical regularposting {yes, sometimes, no };
  input categorical mediaOptimisation {no,trending,past_success};
  input categorical dynamicInteractions {no,yes};
  input categorical remoteContent {no,yes};
  input categorical remoteContentWebsitesDocuments {no,yes};
  input categorical remoteContentDatabase {no,yes};
  input categorical researchPlatformsSocialMedia {yes,no};
  input categorical researchPlatformsEmailWebsitesOther {yes,no};
  input categorical researchsocialMediaPlatforms {twitter, facebook, linkedin, other };
  input categorical researchTends {opinions,trends,needs,others};
  input categorical researchTopics {keywords,hashtags,meaning};
  input categorical researchConfigurable {very,somewhat,no}; //? no point to this.
  input categorical researchMarketingSync {yes,sometimes,no};
  input categorical supportPlatforms {social,skype,whatsap_sms};
  input categorical supportDifficulty {very,somewhat,no};
  input categorical supportExisting {docs,website,database};
  input categorical supportAutoUpdates {yes,no};
  input categorical supportEditable {yes,no};
  input categorical contractOnWeb {yes,no};
  input categorical contractOnEmail {yes,no};
  input categorical contractOnThirdParty{yes,no};
  input categorical contractAccount {yes,no};
  input categorical contractBilling {yes,no};
  input categorical contractSource {few_templates,many_templates,paras,other};
  input categorical contractDifferent {few,many,verymany}; //numeric with sets
  input categorical contractOnlineConfig {yes,no};
  input categorical documentSort {predefined,search,other};
  input categorical documentFormat {pdf_word,web};
  input categorical documentSortAdvise{no,email,im};
  input categorical docChangeCompare {yes,no};
  input categorical advancedPreExisting {app,platform,website,no};
  input categorical advancedBilling {yes,no};
  input categorical advancedAccounts {yes,no};
  input categorical advancedDocuments {yes,no};
  input categorical advancedSocial {yes,no};
  input categorical advancedIm {yes,no};
  input categorical advancedSocialFBLIOther {yes,no};
  input categorical ruleComplexity {simple,difficult,complex};
  input categorical ruleUpdateManual {yes,no};
  input categorical ruleUpdateAuto {yes,no};
  input categorical machineDatabase {yes,no};
  input categorical machineDataSize{small,medium,large,unknown};
  input numeric machineParameters {{small,1,5},{medium,6,10},{large,11,Infinity}};
  input categorical machineCalculated {yes,no};
  input categorical textMiningMeaning {yes,no};
  input categorical textMiningSize {tweets,pages,many_pages};
  input categorical textMiningSpecialized {specific,not_very_specific,general_vocab};
  input categorical textMiningCategorize {yes,no};
  input categorical companySize {startup,sme,large};
  input categorical companyLanguageGerman {yes,no};
  input categorical companyLanguageFrench {yes,no};  
  input categorical companyLanguageSpanish {yes,no};
  input categorical companyLanguageOther {yes,no};
  input textual companyOtherRequirements;
  input textual companyContactName;
  input textual companyName;
  input textual companyEmail;
  input textual companyPhone;
  
  

  
  output numeric docCreationCharge;
  output numeric docCategoryCharge;
  output numeric machineLearningCharge;
  output numeric textminingCharge;
  output numeric chatbotCharge;
  output numeric chatbotFaceBookOtherCharge;
  output numeric salesTrackingCharge;
  output numeric salesteamAccessCharge;
  output numeric estimatingComplexCharge;
  output numeric pdfEstimateCharge;
  output numeric billing_systemCharge;
  output numeric serviceEstimatingComplexCharge;
  output numeric servicePdfEstimateCharge;
  output numeric service_billing_systemCharge;
  output numeric socialMediaPlatformsCharge;
  output numeric mediaOptimisationCharge;
  output numeric dynamicInteractionsCharge;
  output numeric remoteContentWebsitesDocumentsCharge;
  output numeric remoteContentDatabaseCharge;
  output numeric researchsocialMediaPlatformsCharge;
  output numeric supportPlatformsCharge;
  output numeric supportAutoUpdatesCharge;
  output numeric supportEditableCharge;
  output numeric contractAccountCharge;
  output numeric contractBillingCharge;
  output numeric contractOnlineConfigCharge;
  output numeric documentSortCharge;
  output numeric documentFormatCharge;
  output numeric documentSortAdviseCharge;
  output numeric docChangeCompareCharge;
  output numeric advancedPreExistingCharge;
  output numeric advancedBillingCharge;
  output numeric advancedAccountsCharge;
  output numeric advancedDocumentsCharge;
  output numeric advancedSocialFBLIOtherCharge;
  output numeric ruleComplexityCharge;
  output numeric ruleUpdateManualCharge;
  output numeric ruleUpdateAutoCharge;
  output numeric machineDatabaseCharge;
  output numeric machineCalculatedCharge;
  output numeric textMiningMeaningCharge;
  output numeric textMiningSizeCharge;
  output numeric textMiningSpecializedCharge;
  output numeric textMiningCategorizeCharge;
  output numeric companyLanguageGermanCharge;
  output numeric companyLanguageFrenchCharge;
  output numeric companyLanguageSpanishCharge;
  output numeric companyLanguageOtherCharge;
  output numeric offerChangeableCharge;
  
  
  output numeric productCountMultiplier;
  output numeric productOptionsMultiplier;
  output numeric serviceCountMultiplier;
  output numeric serviceChargingMultiplier;
  output numeric supportDifficultyMultiplier;
  output numeric contractDifferentMultiplier;
  output numeric machineDataSizeMultiplier;
  output numeric machineParametersMultiplier;
  output numeric companySizeMultiplier;
  output numeric autoOptimizeCharge;
  output numeric contractOnThirdPartyCharge;
  output numeric contractSourceCharge;
  
  
  
  
  output categorical generalComplete {true,false};
  output numeric price_multipliers;
  output numeric price_sums;
  output numeric total_price;
  
  
  constant creator 2000;
  constant admin 2000;
  constant billing 3500;
  constant account 10000;
  constant tracking 4500;
  constant pdf 250;
  constant learning 10000;
  constant Ruleset 500;
  constant api 1000;
  constant fb 1000;
  constant li 1000;
  constant ne 2000;
  constant Chatbot 2000;
  constant mining 5000;
  
  
  if docCreation is true then docCreationCharge will be creator;
  if docCreation is false then docCreationCharge will be 0;
  if docCategory is true then docCategoryCharge will be creator;
  if docCategory is false then docCategoryCharge will be 0;
  if machineLearning is true then machineLearningCharge will be learning;
  if machineLearning is false then machineLearningCharge will be 0;
  if textMining is true then textminingCharge will be mining;
  if textMining is false then textminingCharge will be 0;
  if chatbot is true then chatbotCharge will be Chatbot;
  if chatbot is false then chatbotCharge will be 0;
  if chatbot is true and chatbotFaceBookOther is true then chatbotFaceBookOtherCharge will be api;
  if chatbot is false or chatbotFaceBookOther is false then chatbotFaceBookOtherCharge will be 0;
  if salesTracking is tracked then salesTrackingCharge will be tracking;
  if salesTracking is tracked_analyzed then salesTrackingCharge will be tracking + admin;
  if salesTracking is no then salesTrackingCharge will be 0;
  if salesteamAccess is yes then salesteamAccessCharge will be account + admin;
  if salesteamAccess is no then salesteamAccessCharge will be 0;
  if offerChangeable is yes then offerChangeableCharge will be admin;
  if offerChangeable is no then offerChangeableCharge will be 0;

  if autoOptimize is yes then autoOptimizeCharge will be learning;
  if autoOptimize is no then autoOptimizeCharge will be 0;

  if productCount is medium and bizmodel is _product then productCountMultiplier will be 1.1;
  if productCount is high and bizmodel is _product then productCountMultiplier will be 1.25;
  if productCount is low and bizmodel is _product then productCountMultiplier will be 1;

  if productOptions is some and bizmodel is _product then productOptionsMultiplier will be 1.025;
  if productOptions is all and bizmodel is _product then productOptionsMultiplier will be 1.05;
  if productOptions is no or bizmodel is service then productOptionsMultiplier will be 1;

  if estimatingComplex is sometimes and bizmodel is _product then estimatingComplexCharge will be Ruleset / 3;
  if estimatingComplex is often and bizmodel is _product then estimatingComplexCharge will be Ruleset / 2;
  if estimatingComplex is always and bizmodel is _product then estimatingComplexCharge will be Ruleset;
  if estimatingComplex is no or bizmodel is service then estimatingComplexCharge will be 0;

  if pdfEstimate is yes and bizmodel is _product then pdfEstimateCharge will be pdf;
  if pdfEstimate is no or bizmodel is service then pdfEstimateCharge will be 0;

  if billing_system is yes and bizmodel is _product then billing_systemCharge will be billing;
  if billing_system is no or bizmodel is service then billing_systemCharge will be 0;


  if serviceCount is medium and bizmodel is service then serviceCountMultiplier will be 1.1;
  if serviceCount is high and bizmodel is service then serviceCountMultiplier will be 1.25;
  if serviceCount is low or bizmodel is _product then serviceCountMultiplier will be 1;


  if serviceCharging is by_hour and bizmodel is service then serviceChargingMultiplier will be 1.025;
  if serviceCharging is by_project and bizmodel is service then serviceChargingMultiplier will be 1.05;
  if serviceCharging is by_use or bizmodel is _product then serviceChargingMultiplier will be 1;

  if serviceEstimatingComplex is sometimes and bizmodel is service then serviceEstimatingComplexCharge will be Ruleset / 3;
  if serviceEstimatingComplex is often and bizmodel is service then serviceEstimatingComplexCharge will be Ruleset / 2;
  if serviceEstimatingComplex is always and bizmodel is service then serviceEstimatingComplexCharge will be Ruleset;
  if serviceEstimatingComplex is no or bizmodel is _product then serviceEstimatingComplexCharge will be 0;

  if servicePdfEstimate is yes and bizmodel is service then servicePdfEstimateCharge will be pdf;
  if servicePdfEstimate is no or bizmodel is _product then servicePdfEstimateCharge will be 0;


  if service_billing_system is yes and bizmodel is service then service_billing_systemCharge will be billing;
  if service_billing_system is no or bizmodel is _product then service_billing_systemCharge will be 0;


  if marketPreference is direct and marketingPlatformsSocialMedia is yes and socialMediaPlatforms is facebook or socialMediaPlatforms is linkedin or socialMediaPlatforms is other then socialMediaPlatformsCharge will be api; 
  if marketPreference is research or marketingPlatformsSocialMedia is no or socialMediaPlatforms is twitter then socialMediaPlatformsCharge will be 0;

  if marketPreference is direct and marketingPlatformsSocialMedia is yes and mediaOptimisation is trending or mediaOptimisation is past_success  then mediaOptimisationCharge will be learning;
  if marketPreference is research or marketingPlatformsSocialMedia is no or mediaOptimisation is no then mediaOptimisationCharge will be 0; 



  if marketPreference is direct and dynamicInteractions is yes then dynamicInteractionsCharge will be Chatbot;
  if marketPreference is research or dynamicInteractions is no then dynamicInteractionsCharge will be 0;


  if marketPreference is direct and remoteContent is yes and remoteContentWebsitesDocuments is yes then remoteContentWebsitesDocumentsCharge will be mining;
  if marketPreference is research or remoteContent is no or remoteContentWebsitesDocuments is no then remoteContentWebsitesDocumentsCharge will be 0;



  if marketPreference is direct and remoteContent is yes and remoteContentDatabase is yes then remoteContentDatabaseCharge will be api;
  if marketPreference is research or remoteContent is no or remoteContentDatabase is no then remoteContentDatabaseCharge will be 0;

  if marketPreference is research and researchPlatformsSocialMedia is yes and not researchsocialMediaPlatforms is twitter then researchsocialMediaPlatformsCharge will be api;
  if marketPreference is direct or researchPlatformsSocialMedia is no or researchsocialMediaPlatforms is twitter then researchsocialMediaPlatformsCharge will be 0;


  if supportWebEmailIM is yes and supportPlatforms is social then supportPlatformsCharge will be api;
  if supportWebEmailIM is no or not supportPlatforms is social then supportPlatformsCharge will be 0;


  if supportWebEmailIM is yes and supportDifficulty is somewhat then supportDifficultyMultiplier will be 1.05;
  if supportWebEmailIM is yes and supportDifficulty is very then supportDifficultyMultiplier will be 1.1;
  if supportWebEmailIM is no or supportDifficulty is no then supportDifficultyMultiplier will be 1;


  if supportWebEmailIM is yes and supportAutoUpdates is yes then supportAutoUpdatesCharge will be learning;
  if supportWebEmailIM is no or supportAutoUpdates is no then supportAutoUpdatesCharge will be 0;

  if supportWebEmailIM is yes and supportEditable is yes then supportEditableCharge will be admin; 
  if supportWebEmailIM is no or supportEditable is no then supportEditableCharge will be 0; 
   
  if docCreation is true and contractOnThirdParty is yes then contractOnThirdPartyCharge will be api;
  if docCreation is false or contractOnThirdParty is no then contractOnThirdPartyCharge will be 0;


  if docCreation is true and contractAccount is yes then contractAccountCharge will be account;
  if docCreation is false or contractAccount is no then contractAccountCharge will be 0;

  if docCreation is true and contractBilling is yes then contractBillingCharge will be billing;
  if docCreation is false or contractBilling is no then contractBillingCharge will be 0;

  if docCreation is true and contractSource is many_templates then contractSourceCharge will be Ruleset;
  if docCreation is true and contractSource is paras then contractSourceCharge will be learning;
  if docCreation is true and contractSource is other then contractSourceCharge will be Ruleset * 3;
  if docCreation is false or contractSource is few_templates then contractSourceCharge will be 0;


  if docCreation is true and contractDifferent is many then contractDifferentMultiplier will be 1.05;
  if docCreation is true and contractDifferent is verymany then contractDifferentMultiplier will be 1.1;
  if docCreation is false or contractDifferent is few then contractDifferentMultiplier will be 1;

  if docCreation is true and contractOnlineConfig is yes then contractOnlineConfigCharge will be admin;
  if docCreation is false or contractOnlineConfig is no then contractOnlineConfigCharge will be 0;

  if docCategory is true and documentSort is predefined then documentSortCharge will be Ruleset;
  if docCategory is true and documentSort is search then documentSortCharge will be admin;
  if docCategory is true and documentSort is other then documentSortCharge will be Ruleset *3;
  if docCategory is false then documentSortCharge will be 0;


  if docCategory is true and documentFormat is pdf_word then documentFormatCharge will be pdf;
  if docCategory is false or documentFormat is web then documentFormatCharge will be 0;

  if docCategory is true and documentSortAdvise is im then documentSortAdviseCharge will be api;
  if docCategory is false or documentSortAdvise is email or documentSortAdvise is no then documentSortAdviseCharge will be 0;



  if docCategory is true and docChangeCompare is yes then docChangeCompareCharge will be Ruleset;
  if docCategory is false or docChangeCompare is no then docChangeCompareCharge will be 0;


  if advanced is true and advancedPreExisting is no then advancedPreExistingCharge will be creator * 2;
  if advanced is true and advancedPreExisting is app then advancedPreExistingCharge will be api;
  if advanced is true and advancedPreExisting is platform then advancedPreExistingCharge will be api;
  if advanced is false or advancedPreExisting is website then advancedPreExistingCharge will be 0;


  if advanced is true and advancedBilling is yes then advancedBillingCharge will be billing;
  if advanced is false or advancedBilling is no then advancedBillingCharge will be 0;

  if advanced is true and advancedAccounts is yes then advancedAccountsCharge will be account;
  if advanced is false or advancedAccounts is no then advancedAccountsCharge will be 0;

  if advanced is true and advancedDocuments is yes then advancedDocumentsCharge will be pdf * 2;
  if advanced is false or advancedDocuments is no then advancedDocumentsCharge will be 0;

  if advanced is true and advancedSocial is yes and advancedSocialFBLIOther is yes then advancedSocialFBLIOtherCharge will be api * 2;
  if advanced is false or advancedSocial is no or advancedSocialFBLIOther is no then advancedSocialFBLIOtherCharge will be 0;


  if ruleComplexity is simple then ruleComplexityCharge will be Ruleset;
  if ruleComplexity is difficult then ruleComplexityCharge will be Ruleset * 2;
  if ruleComplexity is complex then ruleComplexityCharge will be Ruleset * 3;

  if ruleUpdateManual is yes then ruleUpdateManualCharge will be admin;
  if ruleUpdateManual is no then ruleUpdateManualCharge will be 0;

  if ruleUpdateAuto is yes then ruleUpdateAutoCharge will be learning;
  if ruleUpdateAuto is no then ruleUpdateAutoCharge will be 0;

  if machineLearning is true and machineDatabase is yes then machineDatabaseCharge will be api * 2;
  if machineLearning is false or machineDatabase is no then machineDatabaseCharge will be 0;

  if machineLearning is true and machineDataSize is medium then machineDataSizeMultiplier will be 1.025;
  if machineLearning is true and machineDataSize is large then machineDataSizeMultiplier will be 1.05;
  if machineLearning is true and machineDataSize is unknown then machineDataSizeMultiplier will be 1.05;
  if machineLearning is false or machineDataSize is small then machineDataSizeMultiplier will be 1;

  if machineLearning is true and machineParameters is medium then machineParametersMultiplier will be 1.05;
  if machineLearning is true and machineParameters is large then machineParametersMultiplier will be 1.1;
  if machineLearning is false or machineParameters is small then machineParametersMultiplier will be 1;

  if machineLearning is true and machineCalculated is yes then machineCalculatedCharge will be admin * 2;
  if machineLearning is false or machineCalculated is no then machineCalculatedCharge will be 0;

  if textMining is true and textMiningMeaning is yes then textMiningMeaningCharge will be mining; 
  if textMining is false or textMiningMeaning is no then textMiningMeaningCharge will be 0; 

  if textMining is true and textMiningSize is many_pages then textMiningSizeCharge will be Ruleset; 
  if textMining is false or textMiningSize is tweets or textMiningSize is pages then textMiningSizeCharge will be 0; 

  if textMining is true and textMiningSpecialized is specific then textMiningSpecializedCharge will be ne * 2;
  if textMining is true and textMiningSpecialized is not_very_specific then textMiningSpecializedCharge will be ne;   
  if textMining is false or textMiningSpecialized is general_vocab then textMiningSpecializedCharge will be 0;   

  if textMining is true and textMiningCategorize is yes then textMiningCategorizeCharge will be Ruleset * 2;   
  if textMining is false or textMiningCategorize is no then textMiningCategorizeCharge will be 0;   

  if companyLanguageGerman is yes then companyLanguageGermanCharge will be ne confidence 0.5;
  if companyLanguageGerman is yes and marketPreference is research then companyLanguageGermanCharge will be ne * 3 confidence 0.7;
  if companyLanguageGerman is yes and advanced is true then companyLanguageGermanCharge will be ne * 3 confidence 0.7;
  if companyLanguageGerman is yes and docCreation is true then companyLanguageGermanCharge will be ne * 2 confidence 1.0;
  if companyLanguageGerman is yes and docCategory is true then companyLanguageGermanCharge will be ne * 2 confidence 1.0;
  if companyLanguageGerman is no then companyLanguageGermanCharge will be 0;


  if companyLanguageFrench is yes then companyLanguageFrenchCharge will be ne confidence 0.5;
  if companyLanguageFrench is yes and marketPreference is research then companyLanguageFrenchCharge will be ne * 3 confidence 0.7;
  if companyLanguageFrench is yes and advanced is true then companyLanguageFrenchCharge will be ne * 3 confidence 0.7;
  if companyLanguageFrench is yes and docCreation is true then companyLanguageFrenchCharge will be ne * 2 confidence 1.0;
  if companyLanguageFrench is yes and docCategory is true then companyLanguageFrenchCharge will be ne * 2 confidence 1.0;
  if companyLanguageFrench is no then companyLanguageFrenchCharge will be 0;

  if companyLanguageSpanish is yes then companyLanguageSpanishCharge will be ne confidence 0.5;
  if companyLanguageSpanish is yes and marketPreference is research then companyLanguageSpanishCharge will be ne * 3 confidence 0.7;
  if companyLanguageSpanish is yes and advanced is true then companyLanguageSpanishCharge will be ne * 3 confidence 0.7;
  if companyLanguageSpanish is yes and docCreation is true then companyLanguageSpanishCharge will be ne * 2 confidence 1.0;
  if companyLanguageSpanish is yes and docCategory is true then companyLanguageSpanishCharge will be ne * 2 confidence 1.0;
  if companyLanguageSpanish is no then companyLanguageSpanishCharge will be 0;

  if companyLanguageOther is yes then companyLanguageOtherCharge will be ne * 2 confidence 0.5;
  if companyLanguageOther is yes and marketPreference is research then companyLanguageOtherCharge will be ne * 5 confidence 0.7;
  if companyLanguageOther is yes and advanced is true then companyLanguageOtherCharge will be ne * 5 confidence 0.7;
  if companyLanguageOther is yes and docCreation is true then companyLanguageOtherCharge will be ne * 3 confidence 1.0;
  if companyLanguageOther is yes and docCategory is true then companyLanguageOtherCharge will be ne * 3 confidence 1.0;
  if companyLanguageOther is no then companyLanguageOtherCharge will be 0;

  if companySize is sme then companySizeMultiplier will be 1.5;
  if companySize is large then companySizeMultiplier will be 2;
  if companySize is startup then companySizeMultiplier will be 1;
  
  if companyContactName is present and companyName is present and companyEmail is present and companyPhone is present then generalComplete will be true;
  if anything then price_multipliers will be product(productCountMultiplier, productOptionsMultiplier, serviceCountMultiplier, serviceChargingMultiplier, supportDifficultyMultiplier, contractDifferentMultiplier, machineDataSizeMultiplier, machineParametersMultiplier, companySizeMultiplier);
  if anything then price_sums will be sum(docCreationCharge, docCategoryCharge, machineLearningCharge, textminingCharge, chatbotCharge, chatbotFaceBookOtherCharge, salesTrackingCharge, salesteamAccessCharge, estimatingComplexCharge, pdfEstimateCharge, billing_systemCharge, serviceEstimatingComplexCharge, servicePdfEstimateCharge, service_billing_systemCharge, socialMediaPlatformsCharge, mediaOptimisationCharge, dynamicInteractionsCharge, remoteContentWebsitesDocumentsCharge, remoteContentDatabaseCharge, researchsocialMediaPlatformsCharge, supportPlatformsCharge, supportAutoUpdatesCharge, supportEditableCharge, contractAccountCharge, contractBillingCharge, contractOnlineConfigCharge, documentSortCharge, documentFormatCharge, documentSortAdviseCharge, docChangeCompareCharge, advancedPreExistingCharge, advancedBillingCharge, advancedAccountsCharge, advancedDocumentsCharge, advancedSocialFBLIOtherCharge, ruleComplexityCharge, ruleUpdateManualCharge, ruleUpdateAutoCharge, machineDatabaseCharge, machineCalculatedCharge, textMiningMeaningCharge, textMiningSizeCharge, textMiningSpecializedCharge, textMiningCategorizeCharge, companyLanguageGermanCharge, companyLanguageFrenchCharge, companyLanguageSpanishCharge, companyLanguageOtherCharge, offerChangeableCharge);
  if generalComplete is true then total_price will be price_sums * price_multipliers;
  
}