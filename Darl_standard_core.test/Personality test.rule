  "language": {
    "LanguageList": [
      {
        "Name": "item1",
        "Text": "Do you have many different hobbies?",
        "VariantList": [
          {
            "Language": "de",
            "Text": "Haben Sie viele verschiedene Hobbys?"
          },
          {
            "Language": "fr",
            "Text": "Avez-vous beaucoup de hobbies differents ?"
          }
        ]
      },
      {
        "Name": "item2",
        "Text": "Do you stop to think things over before doing anything? ",
        "VariantList": []
      },
      {
        "Name": "item3",
        "Text": "Does your mood often go up and down?",
        "VariantList": []
      },
      {
        "Name": "item4",
        "Text": "Have you ever taken the praise for something you knew someone else had really done?",
        "VariantList": []
      },
      {
        "Name": "item5",
        "Text": "Do you take much notice of what people think?",
        "VariantList": []
      },
      {
        "Name": "item6",
        "Text": "Are you a talkative person?",
        "VariantList": []
      },
      {
        "Name": "item7",
        "Text": "Would being in debt worry you?",
        "VariantList": []
      },
      {
        "Name": "item8",
        "Text": "Do you ever feel just miserable for no reason?",
        "VariantList": []
      },
      {
        "Name": "item9",
        "Text": "Do you give money to charities?",
        "VariantList": []
      },
      {
        "Name": "item10",
        "Text": "Were you ever greedy by helping yourself to more than your share of anything?",
        "VariantList": []
      },
      {
        "Name": "item11",
        "Text": "Are you rather lively? ",
        "VariantList": []
      },
      {
        "Name": "item12",
        "Text": "Would it upset you a lot to see a child or an animal suffer?",
        "VariantList": []
      },
      {
        "Name": "item13",
        "Text": "Do you often worry about things you should not have done or said? ",
        "VariantList": []
      },
      {
        "Name": "item14",
        "Text": "Do you dislike people who don&#x27;t know how to behave themselves?",
        "VariantList": []
      },
      {
        "Name": "item15",
        "Text": "If you say you will do something, do you always keep your promise no matter how inconvenient it might be?",
        "VariantList": []
      },
      {
        "Name": "item16",
        "Text": "Can you usually let yourself go and enjoy yourself at a lively party?",
        "VariantList": []
      },
      {
        "Name": "item17",
        "Text": "Are you an irritable person? ",
        "VariantList": []
      },
      {
        "Name": "item18",
        "Text": "Should people always respect the law?",
        "VariantList": []
      },
      {
        "Name": "item19",
        "Text": "Have you ever blamed someone for doing something you knew was really your fault?",
        "VariantList": []
      },
      {
        "Name": "item20",
        "Text": "Do you enjoy meeting new people?",
        "VariantList": []
      },
      {
        "Name": "item21",
        "Text": "Are good manners very important?",
        "VariantList": []
      },
      {
        "Name": "item22",
        "Text": "Are your feelings easily hurt?",
        "VariantList": []
      },
      {
        "Name": "item23",
        "Text": "Are all your habits good and desirable ones?",
        "VariantList": []
      },
      {
        "Name": "item24",
        "Text": "Do you tend to keep in the background on social occasions?",
        "VariantList": []
      },
      {
        "Name": "item25",
        "Text": "Would you take drugs which may have strange or dangerous effects?",
        "VariantList": []
      },
      {
        "Name": "item26",
        "Text": "Do you often feel &#x27;fed-up&#x27;?",
        "VariantList": []
      },
      {
        "Name": "item27",
        "Text": "Have you ever taken anything (even a pin or button) that belonged to someone else?",
        "VariantList": []
      },
      {
        "Name": "item28",
        "Text": "Do you like going out a lot?",
        "VariantList": []
      },
      {
        "Name": "item29",
        "Text": "Do you prefer to go your own way rather than act by the rules?",
        "VariantList": []
      },
      {
        "Name": "item30",
        "Text": "Do you enjoy hurting people you love?",
        "VariantList": []
      },
      {
        "Name": "item31",
        "Text": "Are you often troubled about feelings of guilt?",
        "VariantList": []
      },
      {
        "Name": "item32",
        "Text": "Do you sometimes talk about things you know nothing about? ",
        "VariantList": []
      },
      {
        "Name": "item33",
        "Text": "Do you prefer reading to meeting people?",
        "VariantList": []
      },
      {
        "Name": "item34",
        "Text": "Do you have enemies who want to harm you?",
        "VariantList": []
      },
      {
        "Name": "item35",
        "Text": "Would you call yourself a nervous person?",
        "VariantList": []
      },
      {
        "Name": "item36",
        "Text": "Do you have many friends?",
        "VariantList": []
      },
      {
        "Name": "item37",
        "Text": "Do you enjoy practical jokes that can sometimes really hurt people?",
        "VariantList": []
      },
      {
        "Name": "item38",
        "Text": "Are you a worrier?",
        "VariantList": []
      },
      {
        "Name": "item39",
        "Text": "As a child did you do as you were told immediately and without grumbling?",
        "VariantList": []
      },
      {
        "Name": "item40",
        "Text": "Would you call yourself happy-go-lucky?",
        "VariantList": []
      },
      {
        "Name": "item41",
        "Text": "Do good manners and cleanliness matter much to you?",
        "VariantList": []
      },
      {
        "Name": "item42",
        "Text": "Have you often gone against your parents&#x27; wishes?",
        "VariantList": []
      },
      {
        "Name": "item43",
        "Text": "Do you worry about awful things that might happen?",
        "VariantList": []
      },
      {
        "Name": "item44",
        "Text": "Have you ever broken or lost something belonging to someone else?",
        "VariantList": []
      },
      {
        "Name": "item45",
        "Text": "Do you usually take the initiative in making new friends?",
        "VariantList": []
      },
      {
        "Name": "item46",
        "Text": "Would you call yourself tense or &#x27;highly-strung&#x27;?",
        "VariantList": []
      },
      {
        "Name": "item47",
        "Text": "Are you mostly quiet when you are with other people?",
        "VariantList": []
      },
      {
        "Name": "item48",
        "Text": "Do you think marriage is old-fashioned and should be done away with?",
        "VariantList": []
      },
      {
        "Name": "item49",
        "Text": "Do you sometimes boast a little?",
        "VariantList": []
      },
      {
        "Name": "item50",
        "Text": "Are you more easy-going about right and wrong than most people?",
        "VariantList": []
      },
      {
        "Name": "item51",
        "Text": "Can you easily get some life into a rather dull party?",
        "VariantList": []
      },
      {
        "Name": "item52",
        "Text": "Do you worry about your health?",
        "VariantList": []
      },
      {
        "Name": "item53",
        "Text": "Have you ever said anything bad or nasty about anyone?",
        "VariantList": []
      },
      {
        "Name": "item54",
        "Text": "Do you enjoy co-operating with others?",
        "VariantList": []
      },
      {
        "Name": "item56",
        "Text": "Do most things taste the same to you?",
        "VariantList": []
      },
      {
        "Name": "item57",
        "Text": "As a child were you ever cheeky to your parents?",
        "VariantList": []
      },
      {
        "Name": "item58",
        "Text": "Do you like mixing with people?",
        "VariantList": []
      },
      {
        "Name": "item59",
        "Text": "Does it worry you if you know there are mistakes in your work?",
        "VariantList": []
      },
      {
        "Name": "item60",
        "Text": "Do you suffer from sleeplessness?",
        "VariantList": []
      },
      {
        "Name": "item61",
        "Text": "Have people said that you sometimes act too rashly?",
        "VariantList": []
      },
      {
        "Name": "item62",
        "Text": "Do you always wash before a meal?",
        "VariantList": []
      },
      {
        "Name": "item63",
        "Text": "Do you nearly always have a &#x27;ready answer&#x27; when people talk to you?",
        "VariantList": []
      },
      {
        "Name": "item64",
        "Text": "Do you like to arrive at appointments in plenty of time?",
        "VariantList": []
      },
      {
        "Name": "item65",
        "Text": "Have you often felt listless and tired for no reason?",
        "VariantList": []
      },
      {
        "Name": "item66",
        "Text": "Have you ever cheated at a game?",
        "VariantList": []
      },
      {
        "Name": "item67",
        "Text": "Do you like doing things in which you have to act quickly?",
        "VariantList": []
      },
      {
        "Name": "item68",
        "Text": "Is (or was) your mother a good woman?",
        "VariantList": []
      },
      {
        "Name": "item69",
        "Text": "Do you often make decisions on the spur of the moment?",
        "VariantList": []
      },
      {
        "Name": "item70",
        "Text": "Do you often feel life is very dull?",
        "VariantList": []
      },
      {
        "Name": "item71",
        "Text": "Have you ever taken advantage of someone?",
        "VariantList": []
      },
      {
        "Name": "item72",
        "Text": "Do you often take on more activities than you have time for?",
        "VariantList": []
      },
      {
        "Name": "item73",
        "Text": "Are there several people who keep trying to avoid you?",
        "VariantList": []
      },
      {
        "Name": "item74",
        "Text": "Do you worry a lot about your looks?",
        "VariantList": []
      },
      {
        "Name": "item75",
        "Text": "Do you think people spend too much time safeguarding their future with savings and insurance?",
        "VariantList": []
      },
      {
        "Name": "item76",
        "Text": "Have you ever wished that you were dead?",
        "VariantList": []
      },
      {
        "Name": "item77",
        "Text": "Would you dodge paying taxes if you were sure you could never be found out?",
        "VariantList": []
      },
      {
        "Name": "item78",
        "Text": "Can you get a party going? ",
        "VariantList": []
      },
      {
        "Name": "item79",
        "Text": "Do you try not to be rude to people?",
        "VariantList": []
      },
      {
        "Name": "item80",
        "Text": "Do you worry too long after an embarrassing experience?",
        "VariantList": []
      },
      {
        "Name": "item81",
        "Text": "Do you generally &#x27;look before you leap&#x27;?",
        "VariantList": []
      },
      {
        "Name": "item82",
        "Text": "Have you ever insisted on having your own way?",
        "VariantList": []
      },
      {
        "Name": "item83",
        "Text": "Do you suffer from &#x27;nerves&#x27;?",
        "VariantList": []
      },
      {
        "Name": "item84",
        "Text": "Do you often feel lonely?",
        "VariantList": []
      },
      {
        "Name": "item85",
        "Text": "Can you on the whole trust people to tell the truth?",
