lineage image "noun:01,7,03";
lineage correct "adjective:3521";
input categorical response {attribute(image)};
output categorical completed {true,false} complete;
output textual annotation;
output categorical correct {true,false} correct;
output categorical answer {attribute(image)} answer;
if response is attribute(answer) then correct will be true;
if anything then answer will be categoryof(response);
if response is present then completed will be true;
if anything then annotation will be attribute(text);