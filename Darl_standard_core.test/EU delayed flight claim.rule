{
  "darl": "ruleset EUDelayClaim\r\n{\r\n  input categorical endsInEU {none, one, both};\r\n  input categorical withinSixYear {true, false};\r\n  input numeric delayInHours {{short,0,2.9},{medium,3,3.9},{long,4,Infinity}};\r\n  input categorical reasonForDelay {security,bad_weather,all_others};\r\n  input numeric flightLength {{short,0,1499},{medium,1500,3499},{long,3500,Infinity}};\r\n  input textual flightNumber;\r\n  input textual bookingRef;\r\n  input textual dateOfFlight;\r\n  input textual timeOfFlight;\r\n  input textual fullName;\r\n  input textual docText;\r\n  input textual cannotClaimText;\r\n  \r\n  output categorical qualifies {true,false};\r\n  output categorical complete {true,false};\r\n  output categorical claim {EU_LT1500, EU_GT1500, EUNEU_LT1500, EUNEUGT_1500, ENEUGT_3500, NO_CLAIM};\r\n  output categorical canClaim {true,false};\r\n  output textual claimText;\r\n  \r\n  \r\n  if endsInEU is one and withinSixYear is true and reasonForDelay is all_others and not delayInHours is short then qualifies will be true;\r\n  if endsInEU is both and withinSixYear is true and reasonForDelay is all_others and not delayInHours is short then qualifies will be true;\r\n  if endsInEU is none or withinSixYear is false or reasonForDelay is security or  reasonForDelay is bad_weather or delayInHours is short then qualifies will be false;\r\n  if flightNumber is present and bookingRef is present and timeOfFlight is present and fullName is present and dateOfFlight is present then complete will be true;\r\n  if qualifies is false then complete will be true;\r\n  \r\n  if qualifies is true and endsInEU is both and flightLength is short and delayInHours is medium then claim will be EU_LT1500;\r\n  if qualifies is true and endsInEU is both and flightLength is short and delayInHours is long then claim will be EU_LT1500;\r\n  if qualifies is true and endsInEU is both and flightLength is medium and delayInHours is medium then claim will be EU_LT1500;\r\n  if qualifies is true and endsInEU is both and flightLength is medium and delayInHours is long then claim will be EU_GT1500;\r\n  if qualifies is true and endsInEU is both and flightLength is long and delayInHours is medium then claim will be EU_GT1500;\r\n  if qualifies is true and endsInEU is both and flightLength is long and delayInHours is long then claim will be EU_GT1500;\r\n  if qualifies is true and endsInEU is one and flightLength is short and delayInHours is medium then claim will be EUNEU_LT1500;\r\n  if qualifies is true and endsInEU is one and flightLength is short and delayInHours is long then claim will be EUNEU_LT1500;\r\n  if qualifies is true and endsInEU is one and flightLength is medium and delayInHours is medium then claim will be EU_LT1500;\r\n  if qualifies is true and endsInEU is one and flightLength is medium and delayInHours is long then claim will be EUNEUGT_1500;\r\n  if qualifies is true and endsInEU is one and flightLength is long and delayInHours is long then claim will be ENEUGT_3500;\r\n  if qualifies is true and endsInEU is one and flightLength is long and delayInHours is medium then claim will be NO_CLAIM;\r\n  if qualifies is true and not claim is NO_CLAIM then canClaim will be true;\r\n  if qualifies is false or claim is NO_CLAIM then canClaim will be false;\r\n  \r\n  if complete is true and canClaim is true then claimText will be document(docText,{flightLength,endsInEU,withinSixYear,delayInHours,reasonForDelay,flightNumber,bookingRef,dateOfFlight,timeOfFlight,fullName,canClaim,claim});\r\n  if canClaim is false then claimText will be cannotClaimText;\r\n}",
  "name": "EU delayed flight claim",
  "version": "1.0.0",
