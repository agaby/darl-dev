{
    "darl": "ruleset EUDelayClaim\n{\n  input categorical endsInEU {none, one, both}; \n  input numeric delayInHours {{short,0,2.9},{medium,3,3.9},{long,4,Infinity}};\n  input categorical reasonForDelay {security,bad_weather,all_others};\n  input numeric flightLength {{short,0,1499},{medium,1500,3499},{long,3500,Infinity}};\n  input textual flightNumber;\n  input textual bookingRef;\n  input temporal dateOfFlight;\n  input textual timeOfFlight;\n  input textual fullName;\n  input textual docText;\n  input textual cannotClaimText;\n  \n  output categorical qualifies {true,false};\n  output categorical complete {true,false};\n  output categorical claim {EU_LT1500, EU_GT1500, EUNEU_LT1500, EUNEUGT_1500, ENEUGT_3500, NO_CLAIM};\n  output categorical canClaim {true,false};\n  output textual claimText;\n  output categorical withinSixYear {true, false};\n  output temporal qualifyingDate;\n  duration sixyears 2190.00:00:00.0;\n  \n  if anything then qualifyingDate will be now - sixyears; \n  if dateOfFlight is after qualifyingDate  then withinSixYear will be true;\n  if dateOfFlight is before qualifyingDate then withinSixYear will be false;\n  if endsInEU is one and withinSixYear is true and reasonForDelay is all_others and not delayInHours is short then qualifies will be true;\n  if endsInEU is both and withinSixYear is true and reasonForDelay is all_others and not delayInHours is short then qualifies will be true;\n  if endsInEU is none or withinSixYear is false or reasonForDelay is security or  reasonForDelay is bad_weather or delayInHours is short then qualifies will be false;\n  if flightNumber is present and bookingRef is present and timeOfFlight is present and fullName is present and dateOfFlight is present then complete will be true;\n  if qualifies is false then complete will be true;\n  \n  if qualifies is true and endsInEU is both and flightLength is short and delayInHours is medium then claim will be EU_LT1500;\n  if qualifies is true and endsInEU is both and flightLength is short and delayInHours is long then claim will be EU_LT1500;\n  if qualifies is true and endsInEU is both and flightLength is medium and delayInHours is medium then claim will be EU_LT1500;\n  if qualifies is true and endsInEU is both and flightLength is medium and delayInHours is long then claim will be EU_GT1500;\n  if qualifies is true and endsInEU is both and flightLength is long and delayInHours is medium then claim will be EU_GT1500;\n  if qualifies is true and endsInEU is both and flightLength is long and delayInHours is long then claim will be EU_GT1500;\n  if qualifies is true and endsInEU is one and flightLength is short and delayInHours is medium then claim will be EUNEU_LT1500;\n  if qualifies is true and endsInEU is one and flightLength is short and delayInHours is long then claim will be EUNEU_LT1500;\n  if qualifies is true and endsInEU is one and flightLength is medium and delayInHours is medium then claim will be EU_LT1500;\n  if qualifies is true and endsInEU is one and flightLength is medium and delayInHours is long then claim will be EUNEUGT_1500;\n  if qualifies is true and endsInEU is one and flightLength is long and delayInHours is long then claim will be ENEUGT_3500;\n  if qualifies is true and endsInEU is one and flightLength is long and delayInHours is medium then claim will be NO_CLAIM;\n  if qualifies is true and not claim is NO_CLAIM then canClaim will be true;\n  if qualifies is false or claim is NO_CLAIM then canClaim will be false;\n  \n  if complete is true and canClaim is true then claimText will be document(docText,{flightLength,endsInEU,withinSixYear,delayInHours,reasonForDelay,flightNumber,bookingRef,dateOfFlight,timeOfFlight,fullName,canClaim,claim});\n  if canClaim is false then claimText will be cannotClaimText;\n}",
