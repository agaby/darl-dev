ruleset FirstProg
{
	input numeric fred {{small, 1, 2, 3},{medium, 2, 3, 4},{large, 3, 4, 5}};
	input numeric bill;
	input categorical john {stupid,clever};
	output categorical brian {angry,sad};
	output numeric andy {{small,5,6,7},{medium,6,7,8},{huge,9,10,11}};
	constant five 5;
	constant six 6;
	string text "hello";

	if anything then brian will be sad;

	if fred is > five and bill is > six then brian will be angry;

	if fred is < five * six or bill is > five / six then brian will be sad;

	if fred is small or fred is large then brian will be angry confidence 0.5;

	if fred is small then andy will be huge;
}