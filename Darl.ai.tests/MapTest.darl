pattern "fred";

ruleset bill
{
	input numeric in1;
	input categorical in2;
	input textual in3;
	output numeric out1;
	output categorical out2;
}


mapinput poop "poop";
mapinput poop2 "poop2";
mapinput poop3 "poop3";

mapoutput whiff "blurble";
mapoutput frfft "blatt";

wire poop bill.in1;
wire poop2 bill.in2;
wire poop3 bill.in3;
wire bill.out1 whiff;
wire bill.out2 frfft;