ruleset vote multiple
{
	input categorical choose {yes, no};
	output categorical vote {out, in};
	if choose is yes then vote will be out;
	otherwise if anything then vote will be in;
}

ruleset tradeterms
{
	input categorical vote {in,out};
	input categorical eumood {hostile, freindly};
	output categorical terms {wto,norway,eu};
	
	if vote is in then terms will be eu; //implicit aggregation: vote is in
	if vote is out and eumood is freindly then terms will be norway;
	if vote is out and eumood is hostile then terms will be wto;
}

mapinput choose;
mapoutput terms;
wire choose vote.choose;
wire tradeterms.terms terms;
wire vote.vote tradeterms.vote;