ruleset cross_border
{
  input categorical source_country {"United Kingdom", "Germany", "United States", "Hong Kong"};
  input categorical dest_country {"United Kingdom", "Germany", "United States", "Hong Kong"};
  input categorical data_type {normal, personal,sensitive};
  input categorical business_purpose {"Customer Relationship Management", "Trades and Transactions","Risk and Control", "Audit", "Compliance", "AML"};
  input categorical personal_condition1 {yes,no};
  input categorical personal_condition2 {yes,no};
  input categorical personal_condition3 {yes,no};
  input categorical personal_condition4 {yes,no};
  input categorical personal_condition5 {yes,no};
  input categorical personal_condition6 {yes,no};
  input textual personal_commentary1;
  input textual personal_commentary2;
  input textual personal_commentary3;
  input textual personal_commentary4;
  input textual personal_commentary5;
  input textual personal_commentary6;
  input categorical sensitive_condition1 {yes,no};
  input categorical sensitive_condition2 {yes,no};
  input categorical sensitive_condition3 {yes,no};
  input categorical sensitive_condition4 {yes,no};
  input textual proof1;
  input textual proof2;
  input textual doc;
  input textual no_doc;
  input textual extra1;
  input textual extra2;
  input textual extra3;
  input textual extra4;
  input textual extra5;
  input categorical extra6 {yes,no};
  input categorical extra7 {yes,no};
  input categorical extra8 {yes,no};
  input categorical extra9 {yes,no};
  input categorical extra10 {yes,no};
  input categorical extra11 {yes,no};
  input categorical extra12 {yes,no};
  
  output categorical background_complete {true, false};
  output categorical transfer_permitted {true, false};
  output textual commentary;
  output categorical interEU {true,false};
  output categorical extraEUPermitted {true,false};
  output categorical extraEUComplete {true,false};
  //conditions to get data not yet used in rules
  if source_country is present and dest_country is present and business_purpose is present then background_complete will be true;
  //personal conditions
  if background_complete is true and data_type is normal then transfer_permitted will be true;
  if background_complete is true and data_type is personal and personal_condition1 is yes and personal_commentary1 is present then transfer_permitted will be true;
  if background_complete is true and data_type is personal and personal_condition2 is yes and personal_commentary2 is present then transfer_permitted will be true;
  if background_complete is true and data_type is personal and personal_condition3 is yes and personal_commentary3 is present then transfer_permitted will be true;
  if background_complete is true and data_type is personal and personal_condition4 is yes and personal_commentary4 is present then transfer_permitted will be true;
  if background_complete is true and data_type is personal and personal_condition5 is yes and personal_commentary5 is present then transfer_permitted will be true;
  if background_complete is true and data_type is personal and personal_condition6 is yes and personal_commentary6 is present then transfer_permitted will be true;
 //sensitive conditions
  if background_complete is true and data_type is sensitive and sensitive_condition1 is yes and proof1 is present then transfer_permitted will be true;
  if background_complete is true and data_type is sensitive and sensitive_condition2 is yes and proof2 is present then transfer_permitted will be true;
  if background_complete is true and data_type is sensitive and sensitive_condition3 is yes then transfer_permitted will be true;
  if background_complete is true and data_type is sensitive and sensitive_condition4 is yes then transfer_permitted will be true;
  if source_country is "United Kingdom" and dest_country is "Germany" then interEU will be true;
  if source_country is "Germany" and dest_country is "United Kingdom" then interEU will be true;
  if source_country is "United Kingdom" and dest_country is "United Kingdom" then interEU will be true;
  if source_country is "Germany" and dest_country is "Germany" then interEU will be true;
  if source_country is "United Kingdom" and dest_country is "United States" then interEU will be false;
  if source_country is "United Kingdom" and dest_country is "Hong Kong" then interEU will be false;
  if source_country is "Germany" and dest_country is "United States" then interEU will be false;
  if source_country is "Germany" and dest_country is "Hong Kong" then interEU will be false;
  
  //negative conditions
  if background_complete is true 
    and data_type is personal and 
    personal_condition1 is no and 
    personal_condition2 is no and
    personal_condition3 is no and
    personal_condition4 is no and
    personal_condition5 is no and
    personal_condition6 is no or
    background_complete is true and
    data_type is sensitive and 
    sensitive_condition1 is no and
    sensitive_condition2 is no and
    sensitive_condition3 is no and
    sensitive_condition4 is no
    then transfer_permitted will be false;
  //external to eu rules
  if interEU is false and extra1 is present and extra2 is present and extra3 is present and extra4 is present and extra5 is present then extraEUComplete will be true; 
  if interEU is true then extraEUComplete will be true;
  if transfer_permitted is true and interEU is true then extraEUPermitted will be true;
  if transfer_permitted is true and interEU is false and extraEUComplete is true and extra6 is yes then extraEUPermitted will be true;
  if transfer_permitted is true and interEU is false and extraEUComplete is true and extra7 is yes then extraEUPermitted will be true;
  if transfer_permitted is true and interEU is false and extraEUComplete is true and extra8 is yes then extraEUPermitted will be true;
  if transfer_permitted is true and interEU is false and extraEUComplete is true and extra9 is yes then extraEUPermitted will be true;
  if transfer_permitted is true and interEU is false and extraEUComplete is true and extra10 is yes then extraEUPermitted will be true;
  if transfer_permitted is true and interEU is false and extraEUComplete is true and extra11 is yes then extraEUPermitted will be true;
  if transfer_permitted is true and interEU is false and extraEUComplete is true and extra12 is yes then extraEUPermitted will be true;
  if transfer_permitted is false then extraEUPermitted will be false;
  if extra6 is no and extra7 is no and extra8 is no and extra9 is no and extra10 is no and extra11 is no and extra12 is no then extraEUPermitted will be false;
  //document creation
  if transfer_permitted is true and extraEUPermitted is true then commentary will be document(doc,{source_country,dest_country,data_type,business_purpose, personal_condition1, personal_condition2, personal_condition3,personal_condition4,personal_condition5,personal_condition6, personal_commentary1,personal_commentary2,personal_commentary3,personal_commentary4,personal_commentary5,personal_commentary6,sensitive_condition1, sensitive_condition2,sensitive_condition3,sensitive_condition4,proof1,proof2 });
  if transfer_permitted is false then commentary will be no_doc;
  if extraEUPermitted is false then commentary will be no_doc;
}