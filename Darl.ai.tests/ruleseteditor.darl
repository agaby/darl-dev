ruleset ruleseteditor 
{ 
  input categorical inputs {%% inputs %%};
  input categorical outputs {%% outputs %%};
  input categorical texts {%% texts %%};
  input categorical edit_type {inputs,outputs,language,trigger,details};
  input textual text_value;
  input textual name_value;
  input textual version_value;
  input textual description_value;
  input textual author_value;
  input textual copyright_value;
  input textual license_value;
  input numeric price_value;
  input categorical currency_value {GBP,USD,EUR};
  input categorical includeIncrement {true,false};
  input numeric increment;
  input categorical includeMaxLength {true,false};
  input numeric maxLength;
  input categorical includeMaxMin {true,false};
  input numeric numericMax;
  input numeric numericMin;
  input categorical includeRegex {true,false};
  input textual regex;
  input categorical showSets {true,false};
  input categorical enforceCrisp {true,false};
  
  string inputMutation "";
  string outputMutation "";
  string languageMutation "";
  string triggerMutation "";
  string detailsMutation "";
  
  output textual mutation;
  output categorical numericIO {true,false};
  output categorical textualIO {true,false};
  
  //insert numeric and textual IO rules here
  %% rules %%
  
  if edit_type is language and texts is present and text_value is present then mutation will be 
    document(languageMutation, {texts,text_value});
  if edit_type is details and name_value is present and version_value is present and description_value is present
    and author_value is present and copyright_value is present and license_value is present and 
    price_value is present and currency_value is present then mutation will be 
    document(detailsMutation, {name_value,version_value,description_value,author_value,copyright_value, license_value,price_value,currency_value});
  if edit_type is inputs and (numericIO is true and includeIncrement is true and increment is present or includeIncrement is false)
    and (includeMaxMin is true and numericMax is present and numericMin is present or includeMaxMin is false) and showSets is present and enforceCrisp is present then mutation will be
    document(inputMutation, {inputs, includeIncrement,increment, includeMaxMin, numericMax, numericMin, showSets, enforceCrisp});
  if edit_type is inputs and textualIO is true and (includeMaxLength is true and maxLength is present or includeMaxLength is false) and (includeRegex is true
    and regex is present or includeRegex is false) then mutation will be document(inputMutation, {inputs,includeMaxLength, maxLength, includeRegex, regex});
}