ruleset military_service
{
  input categorical military {true, false};
  input categorical honorable {true,false};
  input textual name;
  input textual email;
  input textual comply_text;
  input textual non_comply_text;
  
  output categorical military_out {true,false};
  output categorical complies {true,false};
  output categorical trigger {true, false};
  output textual response;
  
  if military is true then military_out will be true;
  if military is false then military_out will be false;
  
  if military_out is true  and honorable is true then complies will be true;
  if military_out is false or honorable is false then complies will be false;
  
  if complies is true and name is present and email is present then trigger will be true;
  otherwise if complies is false then trigger will be false;
  
  if trigger is true then response will be comply_text;
  if trigger is false then response will be non_comply_text;
}
