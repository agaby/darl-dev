      {
        "Name": "RELY",
        "Text": "How reliable must this software be? Think of what's at risk if it fails.",
        "VariantList": []
      },
      {
        "Name": "DATA",
        "Text": "How large will be the collection of tests that must be run against this project?",
        "VariantList": []
      },
      {
        "Name": "CPLX",
        "Text": "How complex is the technology of the project you are planning",
        "VariantList": []
      },
      {
        "Name": "RUSE",
        "Text": "To what extent is the project or substantial parts of it being developed with the intention of re-use later?",
        "VariantList": []
      },
      {
        "Name": "DOCU",
        "Text": "To what extent is the available documentation matched to the needs of the whole development cycle?",
        "VariantList": []
      },
      {
        "Name": "TIME",
        "Text": "How constrained is this project by execution time on the target device?",
        "VariantList": []
      },
      {
