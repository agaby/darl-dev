{
  "darl": "    ruleset COCOMOII\r\n    {\r\n    //Input definitions\r\n    input categorical TYPE  {Early_Design, Post_Architecture};\r\n    input numeric RELY  {{Very_Low , 0.820, 0.820}, {Low , 0.920, 0.920}, {Nominal , 1.000, 1.000}, {High , 1.100, 1.100}, {Very_High , 1.260, 1.260}};\r\n    input numeric DATA  {{Low , 0.900, 0.900}, {Nominal , 1.000, 1.000}, {High , 1.140, 1.140}, {Very_High , 1.280, 1.280}};\r\n    input numeric CPLX  {{Very_Low , 0.730, 0.730}, {Low , 0.870, 0.870}, {Nominal , 1.000, 1.000}, {High , 1.170, 1.170}, {Very_High , 1.340, 1.340}, {Extra_High , 1.740, 1.740}};\r\n    input numeric RUSE  {{Low , 0.950, 0.950}, {Nominal , 1.000, 1.000}, {High , 1.070, 1.070}, {Very_High , 1.150, 1.150}, {Extra_High , 1.240, 1.240}};\r\n    input numeric DOCU  {{Very_Low , 0.810, 0.810}, {Low , 0.910, 0.910}, {Nominal , 1.000, 1.000}, {High , 1.110, 1.110}, {Very_High , 1.230, 1.230}};\r\n    input numeric TIME  {{Nominal , 1.000, 1.000}, {High , 1.110, 1.110}, {Very_High , 1.290, 1.290}, {Extra_High , 1.630, 1.630}};\r\n    input numeric STOR  {{Nominal , 1.000, 1.000}, {High , 1.050, 1.050}, {Very_High , 1.170, 1.170}, {Extra_High , 1.460, 1.460}};\r\n    input numeric PVOL  {{Low , 0.870, 0.870}, {Nominal , 1.000, 1.000}, {High , 1.150, 1.150}, {Very_High , 1.300, 1.300}};\r\n    input numeric ACAP  {{Very_Low , 1.420, 1.420}, {Low , 1.190, 1.190}, {Nominal , 1.000, 1.000}, {High , 0.850, 0.850}, {Very_High , 0.710, 0.710}};\r\n    input numeric PCAP  {{Very_Low , 1.340, 1.340}, {Low , 1.150, 1.150}, {Nominal , 1.000, 1.000}, {High , 0.880, 0.880}, {Very_High , 0.760, 0.760}};\r\n    input numeric PCON  {{Very_Low , 1.290, 1.290}, {Low , 1.120, 1.120}, {Nominal , 1.000, 1.000}, {High , 0.900, 0.900}, {Very_High , 0.810, 0.810}};\r\n    input numeric APEX  {{Very_Low , 1.220, 1.220}, {Low , 1.100, 1.100}, {Nominal , 1.000, 1.000}, {High , 0.880, 0.880}, {Very_High , 0.810, 0.810}};\r\n    input numeric PLEX  {{Very_Low , 1.190, 1.190}, {Low , 1.090, 1.090}, {Nominal , 1.000, 1.000}, {High , 0.910, 0.910}, {Very_High , 0.850, 0.850}};\r\n    input numeric LTEX  {{Very_Low , 1.200, 1.200}, {Low , 1.090, 1.090}, {Nominal , 1.000, 1.000}, {High , 0.910, 0.910}, {Very_High , 0.840, 0.840}};\r\n    input numeric TOOL  {{Very_Low , 1.170, 1.170}, {Low , 1.090, 1.090}, {Nominal , 1.000, 1.000}, {High , 0.900, 0.900}, {Very_High , 0.780, 0.780}};\r\n    input numeric SITE_Collocation  {{Very_Low , 1.220, 1.220}, {Low , 1.090, 1.090}, {Nominal , 1.000, 1.000}, {High , 0.930, 0.930}, {Very_High , 0.860, 0.860}, {Extra_High , 0.800, 0.800}};\r\n    input numeric SITE_communication  {{Very_Low , 1.220, 1.220}, {Low , 1.090, 1.090}, {Nominal , 1.000, 1.000}, {High , 0.930, 0.930}, {Very_High , 0.860, 0.860}, {Extra_High , 0.800, 0.800}};\r\n    input numeric SCED  {{Very_Low , 1.430, 1.430}, {Low , 1.140, 1.140}, {Nominal , 1.000, 1.000}, {High , 1.000, 1.000}, {Very_High , 1.000, 1.000}};\r\n    input numeric PREC  {{Very_Low , 6.200, 6.200}, {Low , 4.960, 4.960}, {Nominal , 3.720, 3.720}, {High , 2.480, 2.480}, {Very_High , 1.240, 1.240}, {Extra_High , 0.000, 0.000}};\r\n    input numeric FLEX  {{Very_Low , 5.070, 5.070}, {Low , 4.050, 4.050}, {Nominal , 3.040, 3.040}, {High , 2.030, 2.030}, {Very_High , 1.010, 1.010}, {Extra_High , 0.000, 0.000}};\r\n    input numeric RESL  {{Very_Low , 7.070, 7.070}, {Low , 5.650, 5.650}, {Nominal , 4.240, 4.240}, {High , 2.830, 2.830}, {Very_High , 1.410, 1.410}, {Extra_High , 0.000, 0.000}};\r\n    input numeric TEAM  {{Very_Low , 5.480, 5.480}, {Low , 4.380, 4.380}, {Nominal , 3.290, 3.290}, {High , 2.190, 2.190}, {Very_High , 1.100, 1.100}, {Extra_High , 0.000, 0.000}};\r\n    input numeric PMAT  {{Very_Low , 7.800, 7.800}, {Low , 6.240, 6.240}, {Nominal , 4.680, 4.680}, {High , 3.120, 3.120}, {Very_High , 1.560, 1.560}, {Extra_High , 0.000, 0.000}};\r\n    input numeric RCPX  {{Extra_Low , 0.490, 0.490}, {Very_Low , 0.600, 0.600}, {Low , 0.830, 0.830}, {Nominal , 1.000, 1.000}, {High , 1.330, 1.330}, {Very_High , 1.910, 1.910}, {Extra_High , 2.720, 2.720}};\r\n    input numeric PDIF  {{Low , 1.000, 1.000}, {Nominal , 1.000, 1.000}, {High , 1.000, 1.000}};\r\n    input numeric PERS  {{Extra_Low , 2.120, 2.120}, {Very_Low , 1.620, 1.620}, {Low , 1.260, 1.260}, {Nominal , 1.000, 1.000}, {High , 0.830, 0.830}, {Very_High , 0.630, 0.630}, {Extra_High , 0.500, 0.500}};\r\n    input numeric PREX  {{Extra_Low , 1.590, 1.590}, {Very_Low , 1.330, 1.330}, {Low , 1.120, 1.120}, {Nominal , 1.000, 1.000}, {High , 0.870, 0.870}, {Very_High , 0.740, 0.740}, {Extra_High , 0.620, 0.620}};\r\n    input numeric FCIL  {{Extra_Low , 1.430, 1.430}, {Very_Low , 1.300, 1.300}, {Low , 1.100, 1.100}, {Nominal , 1.000, 1.000}, {High , 0.870, 0.870}, {Very_High , 0.730, 0.730}, {Extra_High , 0.620, 0.620}};\r\n    input numeric SLOC  {{Very_Low , 1000.000, 1500.000}, {Very_high , 40000.000, 100000.000}};\r\n    input numeric Hourly_rate  {{Very_Low , 10.000, 15.000}, {Very_high , 150.000, 200.000}};\r\n    //Output definitions\r\n    output numeric EFFORT ;\r\n    output numeric DEVTIME ;\r\n    output numeric SIZE ;\r\n    output numeric E ;\r\n    output numeric F ;\r\n    output numeric COST ;\r\n    //numeric constant definitions\r\n    constant A 2.94;\r\n    constant B 0.91;\r\n    constant C 3.67;\r\n    constant D 0.28;\r\n    constant SFScale 0.01;\r\n    constant thousand 1000;\r\n    constant SCHScale 0.2;\r\n    constant Hours_per_month 152;\r\n    //string constant definitions\r\n    //Rule definitions\r\n    if TYPE is Early_Design then EFFORT will be A * SIZE ^ E * product( RCPX , RUSE , PDIF , PERS , PREX , FCIL , SCED ) confidence 1.00;\r\n    if anything then E will be B + SFScale * sum( PREC , FLEX , RESL , TEAM , PMAT ) confidence 1.00;\r\n    if TYPE is Post_Architecture then EFFORT will be A * SIZE ^ E * product( RELY , DATA , CPLX , RUSE , DOCU , TIME , STOR , PVOL , ACAP , PCAP , PCON , APEX , PLEX , LTEX , TOOL , SITE_Collocation , SITE_communication , SCED ) confidence 1.00;\r\n    if anything then SIZE will be SLOC / thousand confidence 1.00;\r\n    if anything then F will be D + SCHScale * ( E - B ) confidence 1.00;\r\n    if anything then DEVTIME will be C * EFFORT ^ F confidence 1.00;\r\n    if anything then COST will be Hourly_rate * Hours_per_month * EFFORT confidence 1.00;\r\n    }\r\n\r\n\r\n    ",
  "name": "Cocomo II",
  "version": "1.0.0",
  "author": "demos",
  "copyright": null,
  "license": null,
  "description": "Price a software development project based on questions about your team, lines of code and hourly rates using the COCOMO II methodology",
