{
  "darl": "ruleset modernslavery\r\n{\r\n  input categorical mspolicyexists {yes,no};\r\n  input categorical mspolicysteps {yes,no};\r\n  input categorical mssupchainexists {yes,no};\r\n  input categorical mssupchainsteps {yes,no};\r\n  input categorical low_risk {yes,no};\r\n  input categorical policystartknown {yes,no};\r\n  input textual mspolicystartdate;\r\n  input categorical companyType {manufacturer,service,other};\r\n  input textual serviceType;\r\n  input textual manufactures;\r\n  input textual sectors;\r\n  input categorical part_of_group {yes,no};\r\n  input textual parent_company;\r\n  input textual parent_domicile;\r\n  input numeric employees;\r\n  input categorical describe_int_trade {country_list,region_list,countrycount,none};\r\n  input textual operating_countries;\r\n  input textual regions;\r\n  input numeric countrycount;\r\n  input numeric turnover;\r\n  input textual email;\r\n  \r\n  input categorical business_organization {count_and_names,description};\r\n  input numeric business_unit_count;\r\n  input textual business_unit_description;\r\n  input textual business_organization_description;\r\n  \r\n  input textual supply_chain_description;\r\n  input categorical supply_chain_extensive {yes,no};\r\n  input textual supply_chain_extension;\r\n  input textual mspolicylink;\r\n  input textual social_policy_link;\r\n  input textual general_due_diligence;\r\n  input categorical ddrisk {yes,no};\r\n  input categorical ddmitigate {yes,no};\r\n  input categorical ddmonitor {yes,no};\r\n  input categorical ddwb {yes,no};\r\n  input categorical supaddZT {yes,no};\r\n  input categorical supaddcompliance {yes,no};\r\n  input categorical supaddrigorous {yes,no};\r\n  input categorical supaddIntolerance {ethics,values,both};\r\n  input textual supaddcomplianceoutline;\r\n  input categorical compliance_team {yes,no};\r\n  input categorical compliance_legal {yes,no};\r\n  input categorical compliance_audit {yes,no};\r\n  input categorical compliance_hr {yes,no};\r\n  input categorical compliance_procurement {yes,no};\r\n  input categorical compliance_sales {yes,no};\r\n  input categorical compliance_other {yes,no};\r\n  input textual compliance_other_desc;\r\n  input categorical training {yes,no};\r\n  input categorical partners_training {yes,no};\r\n  input categorical effectiveness_KPIs  {yes,no};\r\n  input categorical thirdparty  {yes,no};\r\n  input textual KPI_list;\r\n  input textual thirdparty_name;\r\n  input categorical effectiveness_review  {yes,no};\r\n  input categorical thisyear  {yes,no};\r\n  input textual furthersteps;\r\n  input textual financial_year_end;\r\n  input textual signer;\r\n  input categorical signer_role {director,member,general_partner,partner};\r\n  input textual organization_name;\r\n  input categorical socialStatement {yes,no};\r\n  \r\n  output categorical general_complete {true,false};\r\n  output categorical intro_section {A1,A2,A3,B1,B2,B3,C,D,E1,none};\r\n  output categorical qualify {true,false};\r\n  output categorical needstatement {true,false};\r\n  \r\n  if turnover is >= 36000000 and not companyType is other then qualify will be true;\r\n  if turnover is < 36000000 then qualify will be false;\r\n  if companyType is other then qualify will be false;\r\n  \r\n  if qualify is true then needstatement will be true;\r\n  if qualify is false and socialStatement is yes then needstatement will be true;\r\n  if qualify is false and socialStatement is no then needstatement will be false;\r\n  \r\n    \r\n  //catch stuff needed for minimum output\r\n  if mspolicyexists is present and mspolicysteps is present and mssupchainexists is present\r\n    and mssupchainsteps is present and part_of_group is present\r\n    and email is present\r\n    and financial_year_end is present and signer is present and signer_role is present \r\n    and organization_name is present and low_risk is present and needstatement is true\r\n    then general_complete will be true;\r\n  if needstatement is false then general_complete will be true;\r\n  \r\n  if general_complete is true and low_risk is yes then intro_section will be C;\r\n  if general_complete is true and low_risk is no and mspolicyexists is no and mspolicysteps is no then intro_section will be D;\r\n  if general_complete is true and low_risk is no and mspolicyexists is no and mssupchainexists is no and mspolicysteps is yes then intro_section will be A1;\r\n  if general_complete is true and low_risk is no and mspolicyexists is yes and mssupchainexists is no and mspolicysteps is no then intro_section will be A2;\r\n  if general_complete is true and low_risk is no and mspolicyexists is yes and mssupchainexists is no and mspolicysteps is yes then intro_section will be A3;\r\n  if general_complete is true and low_risk is no and mspolicyexists is no and mssupchainexists is yes and mspolicysteps is yes and mssupchainsteps is no then intro_section will be B1;\r\n  if general_complete is true and low_risk is no and mspolicyexists is yes and mssupchainexists is yes and mspolicysteps is no and mssupchainsteps is no then intro_section will be B2;\r\n  if general_complete is true and low_risk is no and mspolicyexists is yes and mssupchainexists is yes and mspolicysteps is yes and mssupchainsteps is no then intro_section will be B3;\r\n  if general_complete is true and low_risk is no and mspolicyexists is yes and mssupchainexists is yes and mspolicysteps is yes and mssupchainsteps is yes and policystartknown is yes and mspolicystartdate is present then intro_section will be E;\r\n  if general_complete is true and low_risk is no and mspolicyexists is yes and mssupchainexists is yes and mspolicysteps is yes and mssupchainsteps is yes and policystartknown is no then intro_section will be E;\r\n  if needstatement is false then intro_section will be none;\r\n}\r\n",
  "name": "modern slavery act statement",
  "version": "1.0.0",
  "author": "demos",
  "copyright": null,
  "license": null,
  "description": "creates a modern slavery act statement for businesses requiring one",
