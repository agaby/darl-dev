{
  "darl": "ruleset military_service\n{\n  input categorical military {true, false};\n  input categorical honorable {true,false};\n  input textual name;\n  input textual email;\n  input textual comply_text;\n  input textual non_comply_text;\n  \n  output categorical military_out {true,false};\n  output categorical complies {true,false};\n  output categorical trigger {true, false};\n  output textual response;\n  \n  if military is true then military_out will be true;\n  otherwise if military is false then military_out will be false;\n  \n  if military_out is true  and honorable is true then complies will be true;\n  if military is false or honorable is false then complies will be false;\n  \n  if complies is true and name is present and email is present then trigger will be true;\n  otherwise if complies is false then trigger will be false;\n  \n  if trigger is true then response will be comply_text;\n  if trigger is false then response will be non_comply_text;\n}",
