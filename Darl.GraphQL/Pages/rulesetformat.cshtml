@page
@model Darl.GraphQL.Pages.rulesetformatModel
@{
    Layout = "_Layoutscrolling";
}

<div class="space-70"></div>
<div class="container margin-b-40">
    <div class="row">
        <div class="col-md-12 margin-b-40">
            <h1>Ruleset format editing</h1>
            <p>Select a ruleset from your account to edit the associated display format.</p>
            <label>Rulesets </label>
            <select id="ruleset-dropdown" name="rulesets" class="dropdown"></select>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12 margin-b-40">
            <div id="format"></div>
            <hr />
        </div>
    </div>
</div>

@section Scripts
{

    <script src="https://cdn.jsdelivr.net/npm/@@json-editor/json-editor@latest/dist/jsoneditor.min.js"></script>
    <script src="/graphql/graphql.min.js"></script>

    <script>

        var editor1;
        var rsname;
        var graph;

        $(async function () {

            var dropdown = $('#ruleset-dropdown');
            dropdown.empty();
            dropdown.append('<option selected="true" disabled>Choose a ruleset to edit</option>');
            dropdown.prop('selectedIndex', 0);
            graph = graphql("/graphql");
            var apiKey = findGetParameter("apikey");
            if (apiKey !== null)
                graph = graphql("/graphql", { headers: { "Authorization": "Basic " + apiKey } });
            var allrulesets = graph(`{ rulesets { name }}`);
            var formatContent = graph(`query getruleset($name: String!){  rulesetByName(name: $name){ ruleform { format{ defaultQuestions inputFormatList { categories enforceCrisp increment inputType maxLength numericMax numericMin path regex showSets name } outputFormatList { displayType hide name outputType path scoreBarColor scoreBarMaxVal scoreBarMinVal uncertainty valueFormat }}}}}`);
            var ursohide = graph('mutation ursohide($ruleset: String!, $name: String!, $val: Boolean!){updateRuleSetOutputFormat(ruleSetName: $ruleset, outputName: $name, outputUpdate: { hide: $val }){ hide }}');
            var ursouncertainty = graph('mutation urso($ruleset: String!, $name: String!, $val: Boolean!){updateRuleSetOutputFormat(ruleSetName: $ruleset, outputName: $name, outputUpdate: { uncertainty: $val }){ uncertainty }}');
            var ursounvalueformat = graph('mutation urso($ruleset: String!, $name: String!, $val: Float!){updateRuleSetOutputFormat(ruleSetName: $ruleset, outputName: $name, outputUpdate: { valueFormat: $val }){ valueFormat }}');
            var ursounbarmax = graph('mutation urso($ruleset: String!, $name: String!, $val: Float!){updateRuleSetOutputFormat(ruleSetName: $ruleset, outputName: $name, outputUpdate: { scoreBarMaxVal: $val }){ scoreBarMaxVal }}');
            var ursounbarmin = graph('mutation urso($ruleset: String!, $name: String!, $val: Float!){updateRuleSetOutputFormat(ruleSetName: $ruleset, outputName: $name, outputUpdate: { scoreBarMinVal: $val }){ scoreBarMinVal }}');
            var ursounbarcolor = graph('mutation urso($ruleset: String!, $name: String!, $val: String!){updateRuleSetOutputFormat(ruleSetName: $ruleset, outputName: $name, outputUpdate: { scoreBarColor: $val }){ scoreBarColor }}');
            var ursodisplaytype = graph('mutation urso($ruleset: String!, $name: String!, $val: String!){updateRuleSetOutputFormat(ruleSetName: $ruleset, outputName: $name, outputUpdate: { displayType: $val }){ displayType }}');
            var ursishowsets = graph('mutation ursi($ruleset: String!, $name: String!, $val: Boolean!){updateRuleSetInputFormat(ruleSetName: $ruleset, inputName: $name, inputUpdate: { showSets: $val }){ showSets }}');
            var ursiincrement = graph('mutation ursi($ruleset: String!, $name: String!, $val: Float!){updateRuleSetInputFormat(ruleSetName: $ruleset, inputName: $name, inputUpdate: { increment: $val }){ increment }}');
            var ursinumericmax = graph('mutation ursi($ruleset: String!, $name: String!, $val: Float!){updateRuleSetInputFormat(ruleSetName: $ruleset, inputName: $name, inputUpdate: { numericMax: $val }){ numericMax }}');
            var ursinumericmin = graph('mutation ursi($ruleset: String!, $name: String!, $val: Float!){updateRuleSetInputFormat(ruleSetName: $ruleset, inputName: $name, inputUpdate: { numericMin: $val }){ numericMin }}');
            var ursimaxlength = graph('mutation ursi($ruleset: String!, $name: String!, $val: String!){updateRuleSetInputFormat(ruleSetName: $ruleset, inputName: $name, inputUpdate: { maxLength: $val }){ maxLength }}');
            var ursiregex = graph('mutation ursi($ruleset: String!, $name: String!, $val: String!){updateRuleSetInputFormat(ruleSetName: $ruleset, inputName: $name, inputUpdate: { regex: $val }){ regex }}');
            const rs = await allrulesets();
            $.each(rs.rulesets, function (key, entry) {
                dropdown.append($('<option class="dropdown-item"></option>').attr('value', entry.name).text(entry.name));
            });

            $('#ruleset-dropdown').on('change', async function () {
                rsname = this.value;
                $("#format").empty();
                editor1 = new JSONEditor(document.getElementById('format'), {
                    theme: 'bootstrap4',
                    schema: {
                        "type": "object",
                        "typeName": "format",
                        "title": "IO format",
                        "additionalProperties": false,
                        "options": {
                            "disable_collapse": true
                        },
                        "required": [
                          "defaultQuestions",
                          "inputFormatList",
                          "outputFormatList"
                        ],
                        "properties": {
                            "defaultQuestions": {
                                "type": "integer",
                                "title": "Default questions",
                                "description": "Maximum number of questions to display per pass",
                                "readonly": true,
                                "maximum": 10.0,
                                "minimum": 1.0,
                                "options": {
                                    "input_width": "50px"
                                }
                            },
                            "inputFormatList": {
                                "type": "array",
                                "format": "table",
                                "title": "Inputs",
                                "description": "Formatting for the inputs of the rule set",
                                "options": {
                                    "disable_array_add": true,
                                    "disable_collapse": true
                                },
                                "items": {
                                    "type": "object",
                                    "typeName": "inputFormat",
                                    "additionalProperties": false,
                                    "required": [
                                      "inType",
                                      "name"
                                    ],
                                    "properties": {
                                        "categories": {
                                            "type": [
                                              "array",
                                              "null"
                                            ],
                                            "readonly": true,

                                            "items": {
                                                "type": "string"
                                            },
                                            "options": {
                                                "hidden": true
                                            }
                                        },
                                        "name": {
                                            "type": "string",
                                            "readonly": true,
                                            "title": "Name",
                                            "options": {
                                                "input_width": "200px"
                                            }
                                        },
                                        "inputType": {
                                            "type": "string",
                                            "readonly": true,
                                            "title": "Type",
                                            "options": {
                                                "input_width": "140px"
                                            }
                                        },
                                        "increment": {
                                            "type": "number",
                                            "title": "Edit increment",
                                            "options": {
                                                "input_width": "100px"
                                            }
                                        },
                                        "maxLength": {
                                            "type": "integer",
                                            "title": "Max length",
                                            "options": {
                                                "input_width": "100px"
                                            }
                                        },
                                        "numericMin": {
                                            "type": "number",
                                            "title": "Min value",
                                            "options": {
                                                "input_width": "100px"
                                            }
                                        },
                                        "numericMax": {
                                            "type": "number",
                                            "title": "Max value",
                                            "options": {
                                                "input_width": "100px"
                                            }
                                        },
                                        "regex": {
                                            "type": "string",
                                            "title": "Regular Expression"
                                        },
                                        "showSets": {
                                            "type": "boolean",
                                            "title": "Show sets",
                                            "options": {
                                                "input_width": "100px"
                                            }
                                        }
                                    },
                                }
                            },
                            "outputFormatList": {
                                "type": "array",
                                "title": "Outputs",
                                "description": "Formatting for the outputs of the rule set",
                                "options": {
                                    "disable_array_add": true,
                                    "disable_collapse": true
                                },
                                "format": "table",
                                "items": {
                                    "type": "object",
                                    "typeName": "OutputFormat",
                                    "additionalProperties": false,
                                    "required": [
                                      "hide",
                                      "name",
                                      "outputType",
                                      "displayType"
                                    ],
                                    "properties": {
                                        "name": {
                                            "type": "string",
                                            "readonly": true,
                                            "title": "Name",
                                            "options": {
                                                "input_width": "200px"
                                            }
                                        },
                                        "outputType": {
                                            "type": "string",
                                            "readonly": true,
                                            "title": "Type",
                                            "options": {
                                                "input_width": "140px"
                                            }
                                        },
                                        "hide": {
                                            "type": "boolean",
                                            "title": "Hide result",
                                            "options": {
                                                "input_width": "100px"
                                            }
                                        },
                                        "displayType": {
                                            "type": "string",
                                            "title": "Display type",
                                            "$ref": "#/definitions/DisplayType",
                                            "options": {
                                                "input_width": "120px"
                                            }
                                        },
                                        "scoreBarColor": {
                                            "type": "string",
                                            "title": "Bar color",
                                            "options": {
                                                "input_width": "100px"
                                            }
                                        },
                                        "scoreBarMaxVal": {
                                            "type": "number",
                                            "title": "Bar max val",
                                            "options": {
                                                "input_width": "100px"
                                            }
                                        },
                                        "scoreBarMinVal": {
                                            "type": "number",
                                            "title": "Bar min val",
                                            "options": {
                                                "input_width": "100px"
                                            }
                                        },
                                        "uncertainty": {
                                            "type": "boolean",
                                            "title": "Uncertainty",
                                            "options": {
                                                "input_width": "100px"
                                            }
                                        },
                                        "valueFormat": {
                                            "type": "string",
                                            "title": "Value format"
                                        }
                                    },
                                }
                            }
                        },
                        "definitions": {
                            "InputType": {
                                "type": "string",
                                "typeName": "InputType",
                                "enum": [
                                  "NUMERIC",
                                  "CATEGORICAL",
                                   "TEXTUAL",
                                   "TEMPORAL"
                                ],
                                "enumNames": [
                                  "numeric",
                                  "categorical",
                                  "textual",
                                  "temporal"
                                ]
                            },
                            "OutType": {
                                "type": "string",
                                "typeName": "OutType",
                                "enum": [
                                  "NUMERIC",
                                  "CATEGORICAL",
                                  "TEXTUAL",
                                  "TEMPORAL"
                                ],
                                "enumNames": [
                                  "numeric",
                                  "categorical",
                                  "textual",
                                  "temporal"
                                ]
                            },
                            "DisplayType": {
                                "type": "string",
                                "typeName": "DisplayType",
                                "enum": [
                                  "TEXT",
                                  "SCOREBAR",
                                  "LINK",
                                  "REDIRECT"
                                ],
                                "enumNames": [
                                  "Text",
                                  "ScoreBar",
                                  "Link",
                                  "Redirect"
                                ]
                            }
                        },
                    },
                    collapsed: true,
                    disable_edit_json: true,
                    disable_properties: true,
                    disable_collapse: false,
                    disable_array_add: false,
                    disable_array_delete: true,
                    disable_array_reorder: true,
                });
                var content = await formatContent({ name: rsname });
                editor1.setValue(content.rulesetByName.ruleform.format);
                var watcherCallback = async function (path) {
                    try {
                        if (path.endsWith('hide')) {
                            //get relative name and value
                            var ioname = editor1.getEditor(path.replace("hide", "name")).getValue();
                            var ioval = editor1.getEditor(path).getValue();
                            await ursohide({ ruleset: rsname, name: ioname, val: ioval });
                        }
                        else if (path.endsWith('uncertainty')) {
                            //get relative name and value
                            var ioname = editor1.getEditor(path.replace("uncertainty", "name")).getValue();
                            var ioval = editor1.getEditor(path).getValue();
                            await ursouncertainty({ ruleset: rsname, name: ioname, val: ioval });
                        }
                        else if (path.endsWith('valueFormat')) {
                            //get relative name and value
                            var ioname = editor1.getEditor(path.replace("valueFormat", "name")).getValue();
                            var ioval = editor1.getEditor(path).getValue();
                            await ursounvalueformat({ ruleset: rsname, name: ioname, val: ioval });
                        }
                        else if (path.endsWith('scoreBarMaxVal')) {
                            //get relative name and value
                            var ioname = editor1.getEditor(path.replace("scoreBarMaxVal", "name")).getValue();
                            var ioval = editor1.getEditor(path).getValue();
                            await ursounbarmax({ ruleset: rsname, name: ioname, val: ioval });
                        }
                        else if (path.endsWith('scoreBarMinVal')) {
                            //get relative name and value
                            var ioname = editor1.getEditor(path.replace("scoreBarMinVal", "name")).getValue();
                            var ioval = editor1.getEditor(path).getValue();
                            await ursounbarmin({ ruleset: rsname, name: ioname, val: ioval });
                        }
                        else if (path.endsWith('scoreBarColor')) {
                            //get relative name and value
                            var ioname = editor1.getEditor(path.replace("scoreBarColor", "name")).getValue();
                            var ioval = editor1.getEditor(path).getValue();
                            await ursounbarcolor({ ruleset: rsname, name: ioname, val: ioval });
                        }
                        else if (path.endsWith('displayType')) {
                            //get relative name and value
                            var ioname = editor1.getEditor(path.replace("displayType", "name")).getValue();
                            var ioval = editor1.getEditor(path).getValue();
                            await ursodisplaytype({ ruleset: rsname, name: ioname, val: ioval });
                        }
                        else if (path.endsWith('showSets')) {
                            //get relative name and value
                            var ioname = editor1.getEditor(path.replace("showSets", "name")).getValue();
                            var ioval = editor1.getEditor(path).getValue();
                            await ursishowsets({ ruleset: rsname, name: ioname, val: ioval });
                        }
                        else if (path.endsWith('increment')) {
                            //get relative name and value
                            var ioname = editor1.getEditor(path.replace("increment", "name")).getValue();
                            var ioval = editor1.getEditor(path).getValue();
                            await ursiincrement({ ruleset: rsname, name: ioname, val: ioval });
                        }
                        else if (path.endsWith('numericMax')) {
                            //get relative name and value
                            var ioname = editor1.getEditor(path.replace("numericMax", "name")).getValue();
                            var ioval = editor1.getEditor(path).getValue();
                            await ursinumericmax({ ruleset: rsname, name: ioname, val: ioval });
                        }
                        else if (path.endsWith('numericMin')) {
                            //get relative name and value
                            var ioname = editor1.getEditor(path.replace("numericMin", "name")).getValue();
                            var ioval = editor1.getEditor(path).getValue();
                            await ursinumericmin({ ruleset: rsname, name: ioname, val: ioval });
                        }
                        else if (path.endsWith('maxLength')) {
                            //get relative name and value
                            var ioname = editor1.getEditor(path.replace("maxLength", "name")).getValue();
                            var ioval = editor1.getEditor(path).getValue();
                            await ursimaxlength({ ruleset: rsname, name: ioname, val: ioval });
                        }
                        else if (path.endsWith('regex')) {
                            //get relative name and value
                            var ioname = editor1.getEditor(path.replace("regex", "name")).getValue();
                            var ioval = editor1.getEditor(path).getValue();
                            await ursiregex({ ruleset: rsname, name: ioname, val: ioval });
                        }
                    }
                    catch (err) {
                        alert(err[0].message);
                    }
                }
                var currentType = 'NUMERIC';
                for (var key in editor1.editors) {
                    if (editor1.editors.hasOwnProperty(key) && key !== 'root') {
                        if (key.endsWith('outputType') || key.endsWith('inputType')) {
                            currentType = editor1.getEditor(key).getValue();
                        }
                        else if (key.endsWith('increment') || key.endsWith('numericMin') || key.endsWith('numericMax') || key.endsWith('showSets') || key.endsWith('scoreBarColor') || key.endsWith('scoreBarMaxVal') || key.endsWith('scoreBarMinVal') || key.endsWith('valueFormat')) {
                            if (currentType !== 'NUMERIC') {
                                editor1.getEditor(key).disable();
                            }
                        }
                        else if(key.endsWith('maxLength') || key.endsWith('regex')){
                            if (currentType !== 'TEXTUAL') {
                                editor1.getEditor(key).disable();
                            }
                        }
                    editor1.watch(key, watcherCallback.bind(editor1, key));
                    }
                }
            });
        });

        function findGetParameter(parameterName) {
            var result = null,
                tmp = [];
            location.search
                .substr(1)
                .split("&")
                .forEach(function (item) {
                    tmp = item.split("=");
                    if (tmp[0] === parameterName) result = decodeURIComponent(tmp[1]);
                });
            return result;
        }

        var charCodeZero = "0".charCodeAt(0);
        var charCodeNine = "9".charCodeAt(0);

        function isDigitCode(n) {
           return(n.charCodeAt(0) >= charCodeZero && n.charCodeAt(0) <= charCodeNine);
        }
    </script>
}
