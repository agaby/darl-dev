@page
@model Darl.GraphQL.Pages.UploadCollateralModel
@using  Darl.GraphQL.Pages
@{
}
<div class="space-70"></div>
<div class="container margin-b-40">
    <div class="row">
        <div class="col-md-12 margin-b-40">
            <h1>Resource uploading</h1>
            <p>Upload Documents or collateral to use with rulesets or bots</p>
            <hr />
        </div>
    </div>
    <div class="row">
        <div class="col-md-12 margin-b-40">
            <form method="post" class="col-sm-6">
                <div class="form-group row">
                    <label asp-for="uploadType" class="col-sm-3 col-form-label"></label>
                    <div class="col-sm-7">
                        <select asp-for="uploadType" asp-items="Html.GetEnumSelectList<UploadCollateralModel.UploadType>()" class="form-control"></select>
                    </div>
                </div>
                <div class="form-group row">
                    <label asp-for="destinationName" class="col-sm-3 col-form-label"></label>
                    <div class="col-sm-7">
                        <input asp-for="destinationName" class="form-control">
                    </div>
                </div>
                <div class="form-group row">
                    <label asp-for="UploadedFile" class="col-sm-3 col-form-label"></label>
                    <div class="col-sm-7">
                        <input asp-for="UploadedFile" class="form-control">
                    </div>
                </div>
                <div class="form-group row">
                    <div class="col-sm-7 offset-sm-3">
                        <button class="btn btn-primary" id="submit">Submit</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>




@section scripts{
    <script>
        $(function () {
            $('#submit').on('click', function (evt) {
                evt.preventDefault();
                $.ajax({
                    url: '',
                    data: new FormData(document.forms[0]),
                    contentType: false,
                    processData: false,
                    type: 'post',
                    success: function () {
                        alert('Upload complete');
                    }
                });
            });
        });
    </script>
}

@section header{
    <meta name="description" content="Upload files required for bots and ruleset in ther DARL GraphQL API." />
}
