@page
@model Darl.GraphQL.Pages.rulesettextModel
@{
    Layout = "_Layoutscrolling";
}

<div class="space-70"></div>
<div class="container margin-b-40">
    <div class="row">
        <div class="col-md-12 margin-b-40">
            <h1>Ruleset text editing</h1>
            <p>Select a ruleset from your account to edit the associated texts.</p>
            <label>Rulesets </label>
            <select id="ruleset-dropdown" name="rulesets" class="dropdown"></select>
        </div>
    </div>
    <div class="row">
        <div class="col-md-12 margin-b-40">
            <div id="language"></div>
            <hr />
        </div>
    </div>
</div>

@section Scripts
{

    <script src="https://cdn.jsdelivr.net/npm/@@json-editor/json-editor@latest/dist/jsoneditor.min.js"></script>
    <script src="/graphql/graphql.min.js"></script>

    <script>

        var editor1;
        var rsname;

        $(async function () {

            var dropdown = $('#ruleset-dropdown');
            dropdown.empty();
            dropdown.append('<option selected="true" disabled>Choose a ruleset to edit</option>');
            dropdown.prop('selectedIndex', 0);
            graph = graphql("/graphql");
            var apiKey = findGetParameter("apikey");
            if (apiKey !== null)
                graph = graphql("/graphql", { headers: { "Authorization": "Basic " + apiKey } });
            var allrulesets = graph(`{ rulesets { name }}`);
            var languageContent = graph(`query getruleset($name: String!){  rulesetByName(name: $name){ ruleform { language { defaultLanguage languageList { text name variantlist { language text }}}}}}`);
            var saveLanguage = graph('mutation updatelang($rulesetname: String!, $name: String!, $text: String!){ updateRuleSetLanguageText(ruleSetName: $rulesetname, languageName: $name, languageText: $text){ name text }}');
            const rs = await allrulesets();
            $.each(rs.rulesets, function (key, entry) {
                dropdown.append($('<option class="dropdown-item"></option>').attr('value', entry.name).text(entry.name));
            });

            $('#ruleset-dropdown').on('change', async function () {
                rsname = this.value;
                $("#language").empty();
                editor1 = new JSONEditor(document.getElementById('language'), {
                    theme: 'bootstrap4',
                    schema: {
                        "type": "object",
                        "typeName": "language",
                        "title": "Language",
                        "additionalProperties": false,
                        "options": {
                            "disable_collapse": true
                        },
                        "required": [
                            "languageList",
                            "defaultLanguage"
                        ],
                        "properties": {
                            "languageList": {
                                "type": "array",
                                "title": "Text items",
                                "format": "table",
                                "options": {
                                    "disable_array_add": true,
                                    "disable_collapse": true
                                },
                                "items": {
                                    "type": "object",
                                    "typeName": "text",
                                    "title": "Text",
                                    "additionalProperties": false,
                                    "required": [
                                        "name",
                                        "text",
                                        "variantList"
                                    ],
                                    "properties": {
                                        "name": {
                                            "type": "string",
                                            "readonly": true,
                                            "title": "Name"
                                        },
                                        "text": {
                                            "type": "string",
                                            "title": "Text",
                                            "format": "textarea",
                                            "options": {
                                                "input_width": "500px"
                                            }
                                        },
                                        "variantList": {
                                            "type": "array",
                                            "title": "Variants",
                                            "format": "table",
                                            "items": {
                                                "type": "object",
                                                "typeName": "variantText",
                                                "additionalProperties": false,
                                                "options": {
                                                    "disable_array_add": false
                                                },
                                                "required": [
                                                    "language",
                                                    "text"
                                                ],
                                                "properties": {
                                                    "language": {
                                                        "type": "string",
                                                        "title": "Language"
                                                    },
                                                    "text": {
                                                        "type": "string",
                                                        "title": "Text"
                                                    }
                                                }
                                            }
                                        }
                                    }
                                },
                            },
                            "defaultLanguage": {
                                "type": "string",
                                "title": "Default language",
                                "description": "ISO standard language",
                                "options": {
                                    "input_width": "100px"
                                }
                            }
                        }
                    },
                    collapsed: true,
                    disable_edit_json: true,
                    disable_properties: true,
                    disable_collapse: false,
                    disable_array_add: false,
                    disable_array_delete: true,
                    disable_array_reorder: true,
                });
                var content = await languageContent({ name: rsname });
                editor1.setValue(content.rulesetByName.ruleform.language);
                var watcherCallback = async function(path) {
                    //ensure path is valid and for a languagelist node, or a variantlist node
                    if (isDigitCode(path.slice(-1))) {
                        if (path.includes('variantList')) {

                        }
                        else {
                            try {
                                var node = this.getEditor(path).getValue()
                                await saveLanguage({ rulesetname: rsname, name: node.name, text: node.text });
                            }
                            catch (err) {
                                alert(err[0].message);
                            }
                        }
                    }
                }
                for (var key in editor1.editors) {
                  if (editor1.editors.hasOwnProperty(key) && key !== 'root') {
                    editor1.watch(key, watcherCallback.bind(editor1, key));
                  }
                }
            });
            rsname = findGetParameter("ruleset");
            if (rsname !== null) {
                $('#ruleset-dropdown').val(rsname).trigger('change');
            }

        });

        function findGetParameter(parameterName) {
            var result = null,
                tmp = [];
            location.search
                .substr(1)
                .split("&")
                .forEach(function (item) {
                    tmp = item.split("=");
                    if (tmp[0] === parameterName) result = decodeURIComponent(tmp[1]);
                });
            return result;
        }

        var charCodeZero = "0".charCodeAt(0);
        var charCodeNine = "9".charCodeAt(0);

        function isDigitCode(n) {
           return(n.charCodeAt(0) >= charCodeZero && n.charCodeAt(0) <= charCodeNine);
        }
    </script>
}