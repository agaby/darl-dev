<header>
    <nav class="navbar navbar-expand-lg navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-4">
        <div class="container">
            <a class="navbar-brand" href="https://darl.ai">
                <img src="/images/logo.png" alt="">
                GraphQL API<span style="color: #0026ff"> &beta;</span>
            </a>
            <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarSupportedContent" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse d-sm-inline-flex flex-sm-row-reverse" id="navbarSupportedContent">
                <ul class="navbar-nav flex-grow-1">
                    <li class="nav-item">
                        <a class="nav-link text-dark" href="index">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" href="api">API</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" href="voyager">API objects</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" href="ThinkBaseVR">VR</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-dark" href="docs">Documentation</a>
                    </li>
                    <li class="nav-item">
                        <a data-toggle="modal" href="#modalPricing" class="nav-link text-dark">Pricing</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link text-dark" href="https://discord.gg/4BaqGFukNG">Discord support</a>
                    </li>
                    <li class="nav-item">
                        @if (!User.Identity.IsAuthenticated)
                        {
                            <a href="/MicrosoftIdentity/account/signin" class="nav-link text-dark"><i class="fas fa-sign-in-alt"></i></a>
                        }
                        else
                        {
                            <a href="/MicrosoftIdentity/account/signout" class="nav-link text-dark" title="Sign out"><i class="fas fa-sign-out-alt"></i></a>
                        }
                    </li>
                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <form method="POST" asp-page="./index">
                                <button class="btn btn-link text-dark" type="submit"><i class="fas fa-file-invoice-dollar" title="Billing"></i></button>
                            </form>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-dark" href="#" id="navbarDropdown" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false" title="API key">
                                <i class="fa fa-key"></i>
                            </a>
                            <div class="dropdown-menu" aria-labelledby="navbarDropdown">
                                <textarea class="dropdown-item text-dark" id="authHeader">{"Authorization": "Basic @User.Claims.Single(a => a.Type == "apikey").Value"}</textarea>
                                <button class="btn btn-link text-dark" type="button" id="copyButton" onclick="copyKey()" title="Copy to clipboard"><i class="far fa-copy"></i></button>
                            </div>
                        </li>            
                    }

                </ul>
            </div>
        </div>
    </nav>
</header>
<script>
    function copyKey ()
    {
        var keyText = $('#authHeader').val();
        navigator.clipboard.writeText(keyText);
    }
</script>
