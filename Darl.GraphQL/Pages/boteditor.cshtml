@page
@model Darl.GraphQL.Pages.boteditorModel
@{
    Layout = "_Layoutscrolling";
}

<div class="space-70"></div>
<div class="container margin-b-40">
    <div class="row">
        <h1>Bot model editing</h1>
    </div>
    <div class="row">
        <div class="col-md-6 margin-b-40">
            <p>Select a bot model from your account to edit.</p>
            <label>Bot models </label>
            <select id="botmodel-dropdown" name="botmodel" class="dropdown"></select>
        </div>
        <div class="col-md-6 margin-b-40">
            <label>Or create a new bot model - choose a unique name.</label>
            <input id="botmodel-input" name="botmodelname" class="form-control">
            <button id="botmodel-create" class="btn btn-info">Create</button>
            <div class="pull-right">
                <label>Empty model? (otherwise default is used)</label>
                <input type="checkbox" id="empty_botmodel" class="checkbox-inline" />
            </div>
        </div>
    </div>
    <div class="space-90"></div>
    <div class="row">
        <div class="col-md-12 margin-b-40">
            <hr/>
            <div class="container">
                <div class=" = row">
                    <h4>Edit Phrases</h4>
                </div>
                <div class="row">
                    <div class="col-md-2">
                        <label>Find phrase</label>
                    </div>
                    <div class="col-md-8">
                        <input class="input form-control" id="findtext" type="text" value="">
                    </div>
                    <div class="col-md-2">
                        <input class="checkbox" type="checkbox" id="phraseexists" readonly disabled="disabled">&nbsp;<label for="phraseexists"> Exists</label>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-2">
                        <label id="patternLabel">Pattern</label>
                    </div>
                    <div class="col-md-8">
                        <input class="input  form-control" id="pattern" type="text" value="">
                    </div>
                </div>
                <div class="row">
                    <br />
                    <div class="btn-group" role="group">
                        <button type="button" class="btn btn-info" id="addbutton" disabled>Add</button>
                        <!--<button type="button" class="btn btn-info" id="mergebutton">Merge</button>-->
                        <button type="button" class="btn btn-danger" id="deletebutton" disabled>Delete</button>
                        <!--<button type="button" class="btn btn-info" id="separatebutton">Separate</button>-->
                    </div>
                </div>
            </div>
            <br />
            <div>
                <h4>Attributes for <i><span id="nodePathText"></span></i></h4>
                <!-- Nav tabs -->
                <ul class="nav nav-tabs" role="tablist">
                    <li class="nav-item"><a class="nav-link active" href="#response" role="tab" data-toggle="tab">Response</a></li>
                    <li class="nav-item"><a class="nav-link" href="#calltab" role="tab" data-toggle="tab">Call</a></li>
                    <li class="nav-item"><a class="nav-link" href="#advanced" role="tab" data-toggle="tab" id="advancedTab">Advanced</a></li>
                </ul>

                <!-- Tab panes -->
                <div class="tab-content">
                    <div class="tab-pane container active" id="response">
                        <div id="responseedit">

                        </div>
                    </div>
                    <div class="tab-pane container" id="calltab">
                        <div id="calledit">

                        </div>
                    </div>
                    <div class="tab-pane container" id="advanced">
                        <div>
                            <label>Darl code</label>
                            <textarea id="code"></textarea>
                        </div>
                        <hr />
                        <div id="roleEdit">
                            <label for="roles">Limit access using authorizations</label><br />
                            <select id="roles"></select>
                        </div>

                    </div>
                </div>
                <div>
                    <button class="btn btn-info pull-right" id="saveAttributes">Save attributes</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section StyleSheets
{
    <link rel="stylesheet" href="/codemirror/theme/neat.css" />
    <link rel="stylesheet" href="/codemirror/codemirror.css" />
    <link rel="stylesheet" href="/codemirror/addon/display/fullscreen.css" />
    <link rel="stylesheet" href="/codemirror/addon/hint/show-hint.min.css" />
    <link rel="stylesheet" href="/codemirror/addon/lint/lint.css" />
    <link rel="stylesheet" href="/codemirror/addon/fold/foldgutter.css" />
    <link rel='stylesheet' href='//cdnjs.cloudflare.com/ajax/libs/font-awesome/4.0.3/css/font-awesome.css'>
}

@section Scripts
{
    <script src="jquery/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@json-editor/json-editor@1.3.5/dist/jsoneditor.min.js"></script>
    <script src="/codemirror/codemirror.js"></script>
    <script src="/codemirror/mode/javascript/javascript.js"></script>
    <script src="/codemirror/addon/display/fullscreen.js"></script>
    <script src="/codemirror/addon/hint/show-hint.js"></script>
    <script src="/codemirror/addon/fold/foldcode.min.js"></script>
    <script src="/codemirror/addon/fold/foldgutter.min.js"></script>
    <script src="/codemirror/addon/fold/brace-fold.min.js"></script>
    <script src="/codemirror/addon/lint/lint.js"></script>
    <script src="/codemirror/addon/lint/json-lint.min.js"></script>
    <script src="/darl-codemirror/darl-codemirror.js"></script>
    <script src="/graphql/graphql.min.js"></script>


    <script>
        var darlCodeMirror;
        var timeout;
        var mdname;
        var attResources;
        var graph;
        var allbotmodels;
        var createDefault;
        var createEmpty;
        var updateAtt;
        var phraseCreate;
        var phraseDelete;

        $(async function () {
            darlCodeMirror = CodeMirror.fromTextArea(document.getElementById("code"), {
                lineNumbers: true,
                theme: 'neat',
                mode: "text/x-darl",
                gutters: ["CodeMirror-lint-markers"],
                extraKeys: { "Ctrl-Space": "autocomplete" },
                lint: {
                    "getAnnotations": CodeMirror.remoteValidator,
                    "async": true,
                    "check_cb": check_syntax
                },
                viewportMargin: Infinity

            });
            //JSONEditor.defaults.options.iconlib = "fontawesome4";

            darlCodeMirror.on("inputRead", function (cm) {
                if (timeout) clearTimeout(timeout);
                timeout = setTimeout(function () {
                    CodeMirror.showHint(cm, CodeMirror.hint.darl, { completeSingle: false });
                }, 150);
            });

            darlCodeMirror.on("keyup", function (cm, event) {
                var keyCode = event.keyCode || event.which;
                if (keyCode == 8 || keyCode == 46) {
                    if (timeout) clearTimeout(timeout);
                    timeout = setTimeout(function () {
                        CodeMirror.showHint(cm, CodeMirror.hint.darl, { completeSingle: false });
                    }, 150);
                }
            });

            graph = graphql("/graphql");
            var apiKey = findGetParameter("apikey");
            if(apiKey !== null)
                graph = graphql("/graphql", { headers: { "Authorization": "Basic " + apiKey } });
            allbotmodels = graph(`{ botmodels { name }}`);
            var attPhrase = graph(`query getAttFromPhrase($model: String!, $phrase: String! ){getAttribute(botModelName: $model, phrase: $phrase ){response call darl accessRoles randomResponse randomResponses path present }}`);
            var attPath = graph(`query getAttFromPath($model: String!, $path: String! ){getAttributeFromPath(botModelName: $model, path: $path ){response call darl accessRoles randomResponse randomResponses path present }}`);
            var attResource = graph(`query getAttResources($model: String!){getLineageNodeAttributeResources(botModelName: $model){allRoles allRulesets ruleSkeleton insertionPointText }}`);
            createDefault = graph('mutation cdbm($name: String!){createDefaultBotModel(name: $name){name }}');
            createEmpty = graph('mutation cebm($name: String!){createEmptyBotModel(name: $name){name }}');
            updateAtt = graph('mutation uab($name: String!, $path: String!, $att: lineageNodeAttributeUpdate!){updateAttribute(botModelName: $name, path: $path, attribute: $att){ path}}');
            phraseCreate = graph('mutation pc($name: String!, $path: String!, $att: lineageNodeAttributeUpdate!){createPhrase(botModelName: $name, path: $path, attribute: $att){ definition}}');
            phraseDelete = graph('mutation pd($name: String!, $phrase: String!){deletePhrase(botModelName: $name, phrase: $phrase){ path}}');
            await updateDropdown();
            $('#botmodel-dropdown').on('change', async function () {
                mdname = this.value;
                attResources = await attResource({ model: mdname });
                if (attResources.getLineageNodeAttributeResources.allRoles.length == 0) {
                    $('#roleEdit').hide();
                }
                else {
                    var options = '<option value="">No authorization</option>';
                    var list = attResources.getLineageNodeAttributeResources.allRoles;
                    for (var x = 0; x < list.length; x++) {
                        options += '<option value="' + list[x]['rowKey'] + '">' + list[x]['name'] + '</option>';
                    }
                    $('#roles').html(options);
                }
                //enable
            });


            var find = $("#findtext");
            var to = false;
            find.on('change', async function (e) {
                var text = $('#findtext').val();
                var r = await attPhrase({ model: mdname, phrase: text });
                if (r != null) {
                    darlCodeMirror.setValue(r.getAttribute.darl);
                    darlCodeMirror.refresh();
                    $('#roles').val(r.getAttribute.accessRoles);
                    editorResponse.setValue(r.getAttribute);
                    editorCall.setValue(r.getAttribute.call);
                    $('#phraseexists').attr('checked', r.getAttribute.present);
                    $("#nodePathText").text(r.getAttribute.path);
                    $("#pattern").val(r.getAttribute.path);
                    if (r.getAttribute.present) {
                        $('#addbutton').attr('disabled', 'disabled');
                        $('#patternLabel').text("Pattern");
                        $('#deletebutton').removeAttr('disabled');
                    }
                    else {
                        $('#addbutton').removeAttr('disabled');
                        $('#patternLabel').text("Suggested pattern");
                        $('#deletebutton').attr('disabled', 'disabled');
                    }
                }
            });


            var top = false;
            $('#pattern').on('change', async function (e) {
                if (top) { clearTimeout(top); }
                top = setTimeout(async function () {
                    var text = $('#pattern').val();
                    var r = await attPath({ model: mdname, path: text });
                    if (r != null && r.code)
                    {
                        darlCodeMirror.setValue(r.darl);
                        rolesSelect.val(r.accessRoles);
                        editorResponse.setValue(r.response);
                        editorCall.setValue(r.call);
                        $("#nodePathText").text(r.path);
                        $('#addbutton').attr('disabled', 'disabled');
                        $('#deletebutton').removeAttr('disabled');
                        darlCodeMirror.refresh();
                    }
                    else
                    {
                        darlCodeMirror.setValue(r.darl);
                        rolesSelect.val(r.accessRoles);
                        $("#nodePathText").text(r.path);
                        $('#addbutton').removeAttr('disabled');
                        $('#deletebutton').attr('disabled', 'disabled');
                    }
                }, 300);
            });

            var editorResponse = new JSONEditor(document.getElementById('responseedit'), {
                theme: 'bootstrap4',
                schema: {
                    "$schema": "http://json-schema.org/draft-04/schema#",
                    "title": "Edit text responses",
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                        "randomResponse": {
                            "title": "Randomly selected responses",
                            "type": "boolean",
                            "format": "checkbox",
                            "description": "If checked one of the random responses will be given, otherwise the single response."
                        },
                       "response": {
                            "title": "A single response",
                            "type": "string",
                           "description": "The text you want to use to respond. Use MarkDown for any formatting.",
                            "format": "textarea",
                            "options": {
                                "input_width": "500px"
                            }
                        },
                        "randomResponses": {
                            "title": "Possible responses",
                            "type": "array",
                            "format": "table",
                            "description": "The text you want to use to respond. Use MarkDown for any formatting.",
                            "items": {
                                "type": "string",
                                "format": "textarea",
                                "options": {
                                    "input_width": "500px"
                                }
                            }
                        }
                    }
                },
                collapsed: true,
                disable_edit_json: true,
                disable_properties: true,
                disable_collapse: true,
                disable_array_add: false,
                disable_array_delete: false,
                disable_array_reorder: true,
                form_name_root: "responses",
                iconlib: 'fontawesome4'
            });

            var editorCall = new JSONEditor(document.getElementById('calledit'), {
                theme: 'bootstrap4',
                schema: {
                    "$schema": "http://json-schema.org/draft-04/schema#",
                    "type": "string",
                    "format": "table",
                    "title": "Called ruleset",
                    "description": "Ruleset that will be called when the phrase is recognized.",
                    "enum": ""
                    },
                collapsed: true,
                disable_edit_json: true,
                disable_properties: true,
                disable_collapse: true,
                disable_array_add: true,
                disable_array_delete: true,
                disable_array_reorder: true,
                form_name_root: "rulesets",
                iconlib: 'fontawesome4'
            });

            $('#addbutton').click(async function (e) {
                try {
                    var path = $("#nodePathText").text();
                    var resp = editorResponse.getValue();
                    await phraseCreate({ name: mdname, path: path, att: { darl: darlCodeMirror.getValue(), call: editorCall.getValue(), response: resp.response, randomResponse: resp.randomResponse, randomResponses: resp.randomResponses } });
                    $("#findtext").change();
                }
                catch (err) {
                    alert(err[0].message);
                }
            });

            $('#deletebutton').click(async function (e) {
                try {
                    var phrase = $('#pattern').val();
                    await phraseDelete({ name: mdname, phrase: phrase });
                    $("#findtext").change();
                }
                catch (err) {
                    alert(err[0].message);
                }
            });

            $("#saveAttributes").on("click", async function (cm, event) {
                try {
                    var path = $("#nodePathText").text();
                    var resp = editorResponse.getValue();
                    await updateAtt({ name: mdname, path: path, att: { darl: darlCodeMirror.getValue(), call: editorCall.getValue(), response: resp.response, randomResponse: resp.randomResponse, randomResponses: resp.randomResponses } });
                }
                catch (err) {
                    alert(err[0].message);
                }
            });



//            $('.nav-tabs a').on('shown.bs.tab', function () {
//            darlCodeMirror.refresh();
//            });

            CodeMirror.commands.autocomplete = function (cm) { cm.showHint({ hint: CodeMirror.hint.darl }); }

            $('#botmodel-create').click(async function () {
                mdname = $('#botmodel-input').val();
                try {
                    if ($('#empty_botmodel').prop('checked')) {
                        var res = await createEmpty({ name: mdname });
                    }
                    else {
                        var res = await createDefault({ name: mdname });
                    }
                    await updateDropdown();
                    alert(mdname + " created");
                }
                catch (err) {
                    alert(err[0].message);
                }              
            });

           $('a[data-toggle="tab"]').on('shown.bs.tab', function (e) {
                darlCodeMirror.refresh();
            });
        });

        async function check_syntax(code, result_cb) {
            var lintCall = graph('query lint($darl: String!, $skeleton String!, $insertion String!){  lintDarl(darl: $darl, skeleton = $skeleton, insertion = $insertion){ column_no_start column_no_stop line_no message severity }}');
            var result = await lintCall({ darl: code, skeleton: attResources.getLineageNodeAttributeResources.ruleSkeleton, insertion: attResources.getLineageNodeAttributeResources.insertionPointText });
            result_cb(result.lintDarl);
        }

        function findGetParameter(parameterName) {
            var result = null,
                tmp = [];
            location.search
                .substr(1)
                .split("&")
                .forEach(function (item) {
                  tmp = item.split("=");
                  if (tmp[0] === parameterName) result = decodeURIComponent(tmp[1]);
                });
            return result;
        }

        async function updateDropdown() {
            const rs = await allbotmodels();
            var dropdown = $('#botmodel-dropdown');
            dropdown.empty();
            dropdown.append('<option selected="true" disabled>Choose a bot model to edit</option>');
            dropdown.prop('selectedIndex', 0);
            $.each(rs.botmodels, function (key, entry) {
                dropdown.append($('<option class="dropdown-item"></option>').attr('value', entry.name).text(entry.name));
            });
        }




    </script>
}

@section header{
    <meta name="description" content="Edits the bot model." />
}
