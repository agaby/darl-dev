@page
@model Darl.GraphQL.Pages.BotTreeModel
@{
    ViewData["Title"] = "BotTree";
    Layout = "~/Pages/_layoutscrolling.cshtml";
}

<div class="modal" id="singleResponseModal" tabindex="-1" role="dialog" aria-labelledby="singleResponseModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="singleResponseModalLabel">Single text response</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <label>Text to return</label>
                <textarea id="singleResponseTextInput"></textarea>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal" id="singleResponseDarl">Create DARL</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="multiResponseModal" tabindex="-1" role="dialog" aria-labelledby="multiResponseModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="multiResponseModalLabel">Random text response</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <label>Texts to return - separate responses with "///" on a new line.</label>
                <textarea id="multiResponseTextInput"></textarea>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Create DARL</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="callResponseModal" tabindex="-1" role="dialog" aria-labelledby="callResponseModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="multiResponseModalLabel">Call a ruleset</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <label>Select a ruleset from your account</label>
                <select id="ruleset-dropdown" name="rulesets" class="dropdown"></select>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Create DARL</button>
            </div>
        </div>
    </div>
</div>


<div class="space-70"></div>
<div class="container margin-b-40">
    <div class="row">
        <h1>Bot model editing</h1>
    </div>
    <div class="row">
        <div class="col-md-6 margin-b-40">
            <p>Select a bot model from your account to edit.</p>
            <label>Bot models </label>
            <select id="botmodel-dropdown" name="botmodel" class="dropdown"></select>
        </div>
        <div class="col-md-6 margin-b-40">
            <label>Or create a new bot model - choose a unique name.</label>
            <input id="botmodel-input" name="botmodelname" class="form-control">
            <button id="botmodel-create" class="btn btn-info">Create</button>
            <div class="pull-right">
                <label>Empty model? (otherwise default is used)</label>
                <input type="checkbox" id="empty_botmodel" class="checkbox-inline" />
            </div>
        </div>
    </div>
    <div class="space-90"></div>
    <div class="row">
        <div class="col-md-12 margin-b-40">
            <hr />
            <div class="container">
                <div class="row">
                    <div class="col-md-3">
                        <h4>Recognition Tree</h4>
                    </div>
                    <div class="col-md-3 ">
                        <button class="btn btn-info pull-right" id="addAtRoot">Add a root entry</button>
                    </div>

                </div>
                <div class="row">
                    <div id="botTree" class="col-md-6 margin-b-40">

                    </div>
                    <div class="col-md-6 margin-b-40">
                        <div>
                            <h4>Attributes for <i><span id="nodePathText"></span></i></h4>
                            <div>
                                <label>Darl code</label>
                                <textarea id="code"></textarea>
                            </div>
                            <div>
                                <h4>Templates</h4>
                                <div class="btn-group" role="group" aria-label="Templates">
                                    <button class="btn btn-info" data-toggle="modal" data-target="#singleResponseModal">Text response</button>
                                    <button class="btn btn-info" data-toggle="modal" data-target="#multiResponseModal">Range of responses</button>
                                    <button class="btn btn-info" data-toggle="modal" data-target="#callResponseModal">Call a ruleset</button>
                                </div>
                            </div>
                            <hr />
                            <div id="roleEdit">
                                <label for="roles">Limit access using authorizations</label><br />
                                <select id="roles" class="dropdown"></select>
                            </div>
                            <div>
                                <button class="btn btn-info pull-right" id="saveAttributes">Save attributes</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


@section StyleSheets
{
    <link rel="stylesheet" href="/codemirror/theme/neat.css" />
    <link rel="stylesheet" href="/codemirror/codemirror.css" />
    <link rel="stylesheet" href="/codemirror/addon/display/fullscreen.css" />
    <link rel="stylesheet" href="/codemirror/addon/hint/show-hint.min.css" />
    <link rel="stylesheet" href="/codemirror/addon/lint/lint.css" />
    <link rel="stylesheet" href="/codemirror/addon/fold/foldgutter.css" />
    <link rel='stylesheet' href='//cdnjs.cloudflare.com/ajax/libs/font-awesome/4.0.3/css/font-awesome.css'>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/jstree/3.2.1/themes/default/style.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/simplemde/latest/simplemde.min.css">
}

@section Scripts
{
    <script src="jquery/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@json-editor/json-editor@1.3.5/dist/jsoneditor.min.js"></script>
    <script src="/codemirror/codemirror.js"></script>
    <script src="/codemirror/mode/javascript/javascript.js"></script>
    <script src="/codemirror/addon/display/fullscreen.js"></script>
    <script src="/codemirror/addon/hint/show-hint.js"></script>
    <script src="/codemirror/addon/fold/foldcode.min.js"></script>
    <script src="/codemirror/addon/fold/foldgutter.min.js"></script>
    <script src="/codemirror/addon/fold/brace-fold.min.js"></script>
    <script src="/codemirror/addon/lint/lint.js"></script>
    <script src="/codemirror/addon/lint/json-lint.min.js"></script>
    <script src="/darl-codemirror/darl-codemirror.js"></script>
    <script src="/graphql/graphql.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jstree/3.2.1/jstree.min.js"></script>
    <script src="https://cdn.jsdelivr.net/simplemde/latest/simplemde.min.js"></script>

    <script language="JavaScript">
        var darlCodeMirror;
        var timeout;
        var mdname;
        var attResources;
        var graph;
        var allbotmodels;
        var createDefault;
        var createEmpty;
        var updateAtt;
        var phraseCreate;
        var phraseDelete;
        var getChildren;
        var deleteNode;
        var createNode;
        var renameNode;
        var pasteNodes;
        var tree;
        var editorResponse;
        var editorCall;
        var lintCall;
        var allrulesets;



        $(async function () {
            darlCodeMirror = CodeMirror.fromTextArea(document.getElementById("code"), {
                lineNumbers: true,
                theme: 'neat',
                mode: "text/x-darl",
                gutters: ["CodeMirror-lint-markers"],
                extraKeys: { "Ctrl-Space": "autocomplete" },
                lint: {
                    "getAnnotations": CodeMirror.remoteValidator,
                    "async": true,
                    "check_cb": check_syntax
                },
                viewportMargin: Infinity

            });



            darlCodeMirror.on("inputRead", function (cm) {
                if (timeout) clearTimeout(timeout);
                timeout = setTimeout(function () {
                    CodeMirror.showHint(cm, CodeMirror.hint.darl, { completeSingle: false });
                }, 150);
            });

            darlCodeMirror.on("keyup", function (cm, event) {
                var keyCode = event.keyCode || event.which;
                if (keyCode == 8 || keyCode == 46) {
                    if (timeout) clearTimeout(timeout);
                    timeout = setTimeout(function () {
                        CodeMirror.showHint(cm, CodeMirror.hint.darl, { completeSingle: false });
                    }, 150);
                }
            });

            var singleMDE = new SimpleMDE({ element: $("#singleResponseTextInput")[0] });
            var multiMDE = new SimpleMDE({ element: $("#multiResponseTextInput")[0] });

            $('#singleResponseDarl').click( function () {
                darlCodeMirror.setValue('if anything then response will be "' + singleMDE.value() + '";');
            });

            graph = graphql("/graphql");
            var apiKey = findGetParameter("apikey");
            if (apiKey !== null)
                graph = graphql("/graphql", { headers: { "Authorization": "Basic " + apiKey } });
            allbotmodels = graph(`{ botmodels { name }}`);
            allrulesets = graph(`{ rulesets { name }}`);
            var attPhrase = graph(`query getAttFromPhrase($model: String!, $phrase: String! ){getAttribute(botModelName: $model, phrase: $phrase ){response call darl accessRoles randomResponse randomResponses path present }}`);
            var attPath = graph(`query getAttFromPath($model: String!, $path: String! ){getAttributeFromPath(botModelName: $model, path: $path ){response call darl accessRoles randomResponse randomResponses path present }}`);
            attResource = graph(`query getAttResources($model: String!){getLineageNodeAttributeResources(botModelName: $model){allRoles allRulesets ruleSkeleton insertionPointText }}`);
            createDefault = graph('mutation cdbm($name: String!){createDefaultBotModel(name: $name){name }}');
            createEmpty = graph('mutation cebm($name: String!){createEmptyBotModel(name: $name){name }}');
            updateAtt = graph('mutation uab($name: String!, $path: String!, $att: lineageNodeAttributeUpdate!){updateAttribute(botModelName: $name, path: $path, attribute: $att){ path}}');
            phraseCreate = graph('mutation pc($name: String!, $path: String!, $att: lineageNodeAttributeUpdate!){createPhrase(botModelName: $name, path: $path, attribute: $att){ definition}}');
            phraseDelete = graph('mutation pd($name: String!, $phrase: String!){deletePhrase(botModelName: $name, phrase: $phrase){ path}}');
            getChildren = graph('query gcln($model: String!, $path: String!, $root: Boolean!){getChildrenLineageNodes(botModelName: $model, path: $path, isRoot: $root){id text children icon data: attributes{ darl call response randomResponse randomResponses definition} }}');
            deleteNode = graph('mutation nd($model: String!, $path: String!){deleteLineageNode(botModelName: $model, id: $path){id text children}}');
            createNode = graph('mutation nc($model: String!, $parent: String!, $text: String!){createLineageNode(botModelName: $model, parent: $parent, newName: $text){id text children}}');
            renameNode = graph('mutation nr($model: String!, $id: String!, $text: String!){renameLineageNode(botModelName: $model, id: $id, newName: $text){id text children}}');
            pasteNodes = graph('mutation pn($model: String!, $parent: String!, $nodes: [String]!, $mode: String!){pasteLineageNode(botModelName: $model, parent: $parent, nodes: $nodes, mode: $mode){id text children}}');
            lintCall = graph('query lint($darl: String!, $skeleton: String!, $insertion: String!){  lintDarl(darl: $darl, skeleton: $skeleton, insertion: $insertion){ column_no_start column_no_stop line_no message severity }}');
            await updateDropdown();
            await updateRulesetDropdown();
            $('#botmodel-dropdown').on('change', async function () {
                mdname = this.value;
                tree = $("#botTree");
                tree.jstree({
                    "core": {
                        "check_callback": true,
                        "data":
                            async function (node, cb) {
                                var isRoot = false;
                                var key = node.id;
                                if (key === "#") {
                                    isRoot = true;
                                }
                                var r = await getChildren({ model: mdname, path: key, root: isRoot });
                                cb.call(this, r.getChildrenLineageNodes);
                            },
                        "types": {
                            "nochild": {
                                "max_children": 0
                            },
                            "themes": {
                                "icons": false
                            }
                        }
                    },
                    "plugins": ["wholerow", "unique", "contextmenu", "types"]
                });
                $("#botTree").on('hover_node.jstree', function (e, data) {
                    if (data.node.data.definition !== null)
                        data.instance.element.prop('title', data.node.data.definition);
                });

                $("#botTree").on('delete_node.jstree', async function (e, data) {
                    await deleteNode({ model: mdname, path: data.node.id })
                    var instance = $('#botTree').jstree(true);
                    instance.delete_node(instance.get_selected());
                });

                $("#botTree").on('select_node.jstree', function (e, data) {
                    if (data.node.data != null) {
                        darlCodeMirror.setValue(data.node.data.darl);
                        var dropdown = $('#roles');
                        dropdown.empty();
                        dropdown.append('<option selected="true" disabled>Choose an authorization role.</option>');
                        $.each(data.node.data.accessRoles, function (key, entry) {
                            dropdown.append($('<option class="dropdown-item"></option>').attr('value', entry).text(entry));
                        });
                        darlCodeMirror.refresh();
                    }
                    else {
                        darlCodeMirror.setValue("");
                        $('#roles').empty();
                        darlCodeMirror.refresh();
                    }
                    $("#nodePathText").text(data.node.id);
                });

                $("#botTree").on('create_node.jstree', async function (e, data) {
                    try {
                        await createNode({ model: mdname, parent: data.parent, text: data.node.text });
                    }
                    catch (err) {
                        alert(err[0].message);
                    }
                });

                $("#botTree").on('rename_node.jstree', async function (e, data) {
                    try {
                        var path;
                        var oldpath;
                        if (data.node.parent === "#") {
                            path = data.node.text.trim();
                            oldpath = data.old.trim();
                        }
                        else {
                            path = data.node.parent + "/" + data.node.text.trim();
                            oldpath = data.node.parent + "/" + data.old.trim();
                        }
                        await renameNode({ model: mdname, id: oldpath.toLowerCase(), text: data.node.text });
                        $('#botTree').jstree(true).set_id(data.node, path.toLowerCase());
                        $('#botTree').jstree(true).refresh_node(data.node);
                    }
                    catch (err) {
                        alert(err[0].message);
                    }
                });

                $("#botTree").on('paste.jstree', async function (e, data) {
                    try {
                        var paths = new Array();
                        for (var i = 0; i < data.node.length; i++)
                            paths[i] = data.node[i].id;
                        await pasteNodes({ model: mdname, parent: data.parent, nodes: paths, mode: data.mode });
                    }
                    catch (err) {
                        alert(err[0].message);
                    }
                });

                attResources = await attResource({ model: mdname });

                $("#saveAttributes").on("click", async function (cm, event) {
                    try {
                        var path = $("#nodePathText").text(); //selected node path
                        await updateAtt({ name: mdname, path: path, att: { darl: darlCodeMirror.getValue(), call: "", response: "", randomResponse: false } });
                        var sel = $("#botTree").jstree(true).get_selected(true);
                        if (sel[0].parent === "#") //root node
                            $("#botTree").jstree(true).refresh();
                        else
                            $("#botTree").jstree(true).refresh_node(sel[0].parent);
                    }
                    catch (err) {
                        alert(err[0].message);
                    }
                });



            });

            CodeMirror.commands.autocomplete = function (cm) { cm.showHint({ hint: CodeMirror.hint.darl }); }

            $('#botmodel-create').click(async function () {
                mdname = $('#botmodel-input').val();
                try {
                    if ($('#empty_botmodel').prop('checked')) {
                        var res = await createEmpty({ name: mdname });
                    }
                    else {
                        var res = await createDefault({ name: mdname });
                    }
                    await updateDropdown();
                    alert(mdname + " created");
                }
                catch (err) {
                    alert(err[0].message);
                }
            });

            $('#addAtRoot').on('click', function (cm, event) {
                $("#botTree").jstree('create_node', '#', { 'id': 'new_node', 'text': 'new_node Text' }, 'last');
            });

        });

        async function check_syntax(code, result_cb) {
            var result = await lintCall({ darl: code, skeleton: attResources.getLineageNodeAttributeResources.ruleSkeleton, insertion: attResources.getLineageNodeAttributeResources.insertionPointText });
            result_cb(result.lintDarl);
        }

        function findGetParameter(parameterName) {
            var result = null,
                tmp = [];
            location.search
                .substr(1)
                .split("&")
                .forEach(function (item) {
                    tmp = item.split("=");
                    if (tmp[0] === parameterName) result = decodeURIComponent(tmp[1]);
                });
            return result;
        }

        async function updateDropdown() {
            const rs = await allbotmodels();
            var dropdown = $('#botmodel-dropdown');
            dropdown.empty();
            dropdown.append('<option selected="true" disabled>Choose a bot model to edit</option>');
            dropdown.prop('selectedIndex', 0);
            $.each(rs.botmodels, function (key, entry) {
                dropdown.append($('<option class="dropdown-item"></option>').attr('value', entry.name).text(entry.name));
            });
        }

        async function updateRulesetDropdown() {
            const rs = await allrulesets();
            var dropdown = $('#ruleset-dropdown');
            dropdown.empty();
            dropdown.append('<option selected="true" disabled>Choose a ruleset to call</option>');
            dropdown.prop('selectedIndex', 0);
            $.each(rs.rulesets, function (key, entry) {
                dropdown.append($('<option class="dropdown-item"></option>').attr('value', entry.name).text(entry.name));
            });
        }


    </script>
}

@section header{
    <meta name="description" content="Edits the bot model." />
}

