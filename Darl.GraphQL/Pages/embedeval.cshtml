@page
@{
    Layout = "_BlankLayout";
}

<!DOCTYPE html>

<div class="container">
    <div class="row">
        <div class="col-md-12">
            <div class="grey-bg card ">
                <div class="card-body" id="ruleform">
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts
{
    <script src="/graphql/graphql.min.js"></script>
    <script src="darl-formql/darl-formql.js"></script>

    <script>

        $(async function () {
            var graph = graphql("/graphql");
            var apiKey = findGetParameter("apikey");
            if (apiKey !== null)
                graph = graphql("/graphql", { headers: { "Authorization": "Basic " + apiKey } });
            var rsname = findGetParameter("ruleset");
            if (rsname === null) {
                alert("To use the embedded evaluator you must supply a ruleset in the form ?ruleset=<ruleset name>.");
                return;
            }
            try {
                var form = await DARLForm('#ruleform', rsname, false, apiKey);
            }
            catch (err) {
                alert(err[0].message);
            }
        });

        function findGetParameter(parameterName) {
            var result = null,
                tmp = [];
            location.search
                .substr(1)
                .split("&")
                .forEach(function (item) {
                    tmp = item.split("=");
                    if (tmp[0] === parameterName) result = decodeURIComponent(tmp[1]);
                });
            return result;
        }
    </script>
}