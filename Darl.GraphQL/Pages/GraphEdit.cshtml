                var div = $("<div>", {
                    css: {
                        "width": "100%",
                        "margin-top": "1rem"
                    }
                }).html(html);

                $.MessageBox({
                    message: "Information",
                    input: div
                }).done(function (data) {
                    console.log(data);
                });
            });
        }

