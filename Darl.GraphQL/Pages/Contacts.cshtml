@page "{handler?}"
@model Darl.GraphQL.Pages.ContactsModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Contacts</title>
    <style>
        body {
            height: 100%;
            margin: 0;
            overflow: auto;
            width: 100%;
        }
    </style>

    <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.3.1/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet" type="text/css" />
    <link href="https://unpkg.com/gijgo@1.9.13/css/gijgo.min.css" rel="stylesheet" type="text/css" />
</head>
<body>
    @Html.AntiForgeryToken()

    <div class="space-70"></div>
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-8">
                <form class="form-inline">
                    <div class="form-group">
                        <input id="txtName" type="text" placeholder="last Name..." class="form-control" />
                        <input id="txtCompany" type="text" placeholder="Company..." class="form-control" />
                    </div>
                    <button id="btnSearch" type="button" class="btn btn-default">Search</button>
                    <button id="btnClear" type="button" class="btn btn-default">Clear</button>
                </form>
            </div>
            <div class="col-md-4">
                <button id="btnAdd" type="button" class="btn btn-default pull-right">Add New Record</button>
            </div>
        </div>
        <div class="row" style="margin-top: 10px">
            <div class="col-md-12">
                <table id="grid"></table>
            </div>
        </div>
    </div>

    <div id="dialog" style="display: none">
        <input type="hidden" id="id" />
        <form>
            <div class="form-group">
                <label for="firstName">First Name</label>
                <input type="text" class="form-control" id="firstName">
            </div>
            <div class="form-group">
                <label for="lastName">Last Name</label>
                <input type="text" class="form-control" id="lastName">
            </div>
            <div class="form-group">
                <label for="email">Email</label>
                <input type="email" class="form-control" id="email">
            </div>
            <div class="form-group">
                <label for="phone">Phone</label>
                <input type="tel" class="form-control" id="phone">
            </div>
            <div class="form-group">
                <label for="country">Country</label>
                <input type="text" class="form-control" id="country">
            </div>
            <div class="form-group">
                <label for="company">Company</label>
                <input type="text" class="form-control" id="company">
            </div>
            <div class="form-group">
                <label for="title">Title</label>
                <input type="text" class="form-control" id="title">
            </div>
            <div class="form-group">
                <label for="notes">Notes</label>
                <input type="text" class="form-control" id="notes">
            </div>
            <div class="form-group">
                <label for="notes">Sector</label>
                <input type="text" class="form-control" id="sector">
            </div>
            <button type="button" id="btnSave" class="btn btn-default">Save</button>
            <button type="button" id="btnCancel" class="btn btn-default">Cancel</button>
        </form>
    </div>

    <script src="~/jquery/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.12.3/umd/popper.min.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.3.1/js/bootstrap.min.js"></script>
    <script src="https://unpkg.com/gijgo@1.9.13/js/gijgo.min.js" type="text/javascript"></script>

    <script type="text/javascript">

        var grid, dialog;
        var apiKey;

        function Edit(e) {
            $('#id').val(e.data.record.id);
            $('#firstName').val(e.data.record.firstName);
            $('#lastName').val(e.data.record.lastName);
            $('#email').val(e.data.record.email);
            $('#phone').val(e.data.record.phone);
            $('#country').val(e.data.record.country);
            $('#company').val(e.data.record.company);
            $('#title').val(e.data.record.title);
            $('#notes').val(e.data.record.notes);
            $('#sector').val(e.data.record.sector);
            dialog.open('Add Contact');
        }
        function Save() {
            var contact = {
                id: $('#id').val(),
                firstName: $('#firstName').val(),
                lastName: $('#lastName').val(),
                email: $('#email').val(),
                phone: $('#phone').val(),
                country: $('#country').val(),
                company: $('#company').val(),
                title: $('#title').val(),
                source: 'manual',
                notes: $('#notes').val(),
                sector: $('#sector').val()
            };
            $.ajax({
                url: '/Contacts/Create', data: { contact: JSON.stringify(contact) }, method: 'POST',
                beforeSend: function (xhr) {
                    xhr.setRequestHeader("XSRF-TOKEN",
                        $('input:hidden[name="__RequestVerificationToken"]').val());
                    xhr.setRequestHeader("apikey", apiKey);
                }
            })
                .done(function () {
                    dialog.close();
                    grid.reload();
                })
                .fail(function () {
                    alert('Failed to save.');
                    dialog.close();
                });
        }

        $(document).ready(function () {

            apiKey = findGetParameter("apikey");

            grid = $('#grid').grid({
                primaryKey: 'id',
                dataSource: {
                    url: '/Contacts/Data', method: 'GET', data: {}, beforeSend: function (xhr) { xhr.setRequestHeader("apikey", apiKey); }
                },
                uiLibrary: 'bootstrap4',
                inlineEditing: { mode: 'command' },
                resizableColumns: true,
                columns: [
                    { field: 'id', hidden: true },
                    { field: 'firstName', title: 'First name', sortable: true, editor: true },
                    { field: 'lastName', title: 'Last name', sortable: true, editor: true },
                    { field: 'email', title: 'Email', sortable: true, editor: true },
                    { field: 'phone', title: 'phone', sortable: true, editor: true },
                    { field: 'country', title: 'Country', sortable: true, width: 150, editor: true },
                    { field: 'company', title: 'Company', sortable: true, editor: true },
                    { field: 'title', title: 'Title', sortable: true, width: 64, editor: true },
                    { field: 'source', title: 'Source', sortable: true, editor: true },
                    { field: 'created', title: 'Created', sortable: true, type: 'date', format: 'dd/mm/yy', editor: true },
                    { field: 'notes', title: 'Notes', sortable: true, editor: true },
                    { field: 'sector', title: 'Sector', sortable: true, editor: true }
                ],
                pager: { limit: 10 }
            });

            dialog = $('#dialog').dialog({
                uiLibrary: 'bootstrap',
                iconsLibrary: 'fontawesome',
                autoOpen: false,
                resizable: false,
                modal: true
            });


            $('#btnAdd').on('click', function () {
                $('#contactId').val('');
                $('#firstName').val('');
                $('#lastName').val('');
                $('#email').val('');
                $('#phone').val('');
                $('#country').val('');
                $('#company').val('');
                $('#title').val('');
                $('#source').val('');
                $('#notes').val('');
                $('#sector').val('');
                dialog.open('Add Contact');
            });

            $('#btnSave').on('click', Save);

            $('#btnCancel').on('click', function () {
                dialog.close();
            });

            $('#btnSearch').on('click', function () {
                grid.reload({ lastName: $('#txtName').val(), company: $('#txtCompany').val() });
            });

            $('#btnClear').on('click', function () {
                $('#txtName').val('');
                $('#txtCompany').val('');
                grid.reload({ lastName: '', country: '' });
            });

            grid.on('rowDataChanged', function (e, id, record) {
                $.ajax({
                    url: '/Contacts/Update', data: { contact: JSON.stringify(record) }, method: 'POST',
                    beforeSend: function (xhr) {
                        xhr.setRequestHeader("XSRF-TOKEN",
                            $('input:hidden[name="__RequestVerificationToken"]').val());
                        xhr.setRequestHeader("apikey", apiKey);
                    }
                })
                    .fail(function () {
                        alert('Failed to save.');
                    });
            });

            grid.on('rowRemoving', function (e, $row, id, record) {
                $.ajax({
                    url: '/Contacts/Delete', data: { id: record.email }, method: 'POST',
                    beforeSend: function (xhr) {
                        xhr.setRequestHeader("XSRF-TOKEN",
                            $('input:hidden[name="__RequestVerificationToken"]').val());
                        xhr.setRequestHeader("apikey", apiKey);
                    }
                })
                    .done(function () {
                        grid.reload();
                    })
                    .fail(function () {
                        alert('Failed to delete.');
                    })
            });

        });

        function findGetParameter(parameterName) {
            var result = null,
                tmp = [];
            location.search
                .substr(1)
                .split("&")
                .forEach(function (item) {
                    tmp = item.split("=");
                    if (tmp[0] === parameterName) result = decodeURIComponent(tmp[1]);
                });
            return result;
        }
    </script>

</body>
</html>


