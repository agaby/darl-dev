@page
@model Darl.GraphQL.Pages.docsModel
@{
    ViewData["Title"] = "ThinkBase documentation";
    Layout = "~/Pages/_docslayout.cshtml";
}

<div id="app"></div>
<script>
    window.$docsify = {
        basePath: '/md/',
        loadSidebar: true,
        loadNavbar: true,
        mergeNavbar: true,
        name: 'ThinkBase',
        namelink: '../',
        logo: '/images/darl_graphic_small.png',
        homepage: 'Index.md',
        ga: 'UA-117408682-4',
        search: {
            paths: 'auto'
        }
    };
</script>

@section StyleSheets
{
    <link rel="stylesheet" href="//cdn.jsdelivr.net/npm/docsify@4/themes/vue.css" />
}

@section Scripts
{
    <script src="//cdn.jsdelivr.net/npm/docsify@4"></script>
    <script src="//cdn.jsdelivr.net/npm/docsify/lib/plugins/search.min.js"></script>
    <script src="//cdn.jsdelivr.net/npm/docsify/lib/plugins/ga.min.js"></script>
    <script src="//cdn.jsdelivr.net/npm/docsify-copy-code"></script>
}