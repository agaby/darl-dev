@page
@model Darl.GraphQL.Container.Pages.IndexModel
@{
     Layout = "~/Pages/_layoutContainer.cshtml";
 }

<div class="row">
    <div class="col-xs-12 col-sm-12 col-md-12  ">
        <iframe style="width: 100vw;height: 90vh;position: relative;" src="ui/playground" frameborder="0" allowfullscreen align="top"></iframe>
    </div>
</div>

@section StyleSheets
{
    <link rel="stylesheet" href="/font-awesome/css/fontawesome.min.css" />
}

@section header{
    <meta name="description" content="Interact with the DARL GraphQL API using the Playground interface." />
}

@section Scripts
{
    <script src="/font-awesome/js/all.js"></script>
}

